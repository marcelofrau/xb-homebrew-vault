<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="XBVault.Views.BrowseView">

  <Grid RowDefinitions="Auto,Auto,*" Margin="32">

    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="0,24,0,16">
      <TextBlock Text="BROWSE"
                 Classes="PageTitle"/>
      <TextBlock Text="Discover homebrew apps and emulators from Emulation Revival"
                 Classes="Muted"
                 FontSize="14"
                 Margin="0,4,0,0"/>
    </StackPanel>

    <!-- Search + Filters (hidden in detail view) -->
    <Grid Grid.Row="1"
          ColumnDefinitions="*,Auto,Auto"
          ColumnSpacing="12"
          Margin="0,0,0,16"
          IsVisible="{Binding IsDetailVisible, Converter={StaticResource BoolInverse}}">

      <TextBox Watermark="Search catalog..."
               Text="{Binding SearchText}"
               Padding="12,8"/>

      <ComboBox Grid.Column="1"
                ItemsSource="{Binding Categories}"
                SelectedItem="{Binding SelectedCategory}"
                Width="140"
                Padding="8,6"/>

      <CheckBox Grid.Column="2"
                IsChecked="{Binding ShowExperimental}"
                Foreground="{StaticResource TextMutedBrush}"
                FontSize="12"
                VerticalAlignment="Center">
        <TextBlock Text="Show experimental"/>
      </CheckBox>
    </Grid>

    <!-- Loading -->
    <TextBlock Grid.Row="2"
               Text="Loading catalog..."
               IsVisible="{Binding IsLoading}"
               Foreground="{StaticResource TextMutedBrush}"
               FontSize="14"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>

    <!-- Empty state -->
    <StackPanel Grid.Row="2"
                IsVisible="{Binding HasItems, Converter={StaticResource BoolInverse}}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
      <TextBlock Text="No items found"
                 FontSize="16"
                 Foreground="{StaticResource TextMutedBrush}"
                 HorizontalAlignment="Center"/>
      <TextBlock Text="Adjust your search or filters"
                 FontSize="13"
                 Foreground="{StaticResource TextDimBrush}"
                 HorizontalAlignment="Center"/>
    </StackPanel>

    <!-- Catalog Grid -->
    <ListBox Grid.Row="2"
             ItemsSource="{Binding Items}"
             SelectedItem="{Binding SelectedItem}"
             BorderThickness="0"
             Background="Transparent"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             IsVisible="{Binding HasItems}">
      <ListBox.ItemsPanel>
        <ItemsPanelTemplate>
          <WrapPanel Orientation="Horizontal"/>
        </ItemsPanelTemplate>
      </ListBox.ItemsPanel>
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Classes="Card"
                  Padding="16"
                  Width="220"
                  MinHeight="200"
                  Margin="0,0,16,16"
                  Cursor="Hand">
            <Border.Styles>
              <Style Selector="Border:pointerover">
                <Setter Property="BorderBrush" Value="{StaticResource AccentDimBrush}"/>
              </Style>
            </Border.Styles>
            <StackPanel Spacing="8">
              <Border Width="48" Height="48"
                      CornerRadius="4"
                      Background="{StaticResource SurfaceAltBrush}"
                      HorizontalAlignment="Left">
                <TextBlock Text="XB"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
              </Border>
              <TextBlock Text="{Binding Name}"
                         FontSize="14"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap"/>
              <TextBlock Text="{Binding Description}"
                         FontSize="11"
                         Foreground="{StaticResource TextMutedBrush}"
                         TextWrapping="Wrap"
                         MaxHeight="48"/>
              <TextBlock Text="{Binding Category}"
                         FontSize="10"
                         Foreground="{StaticResource AccentBrush}"
                         TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <!-- Detail View -->
    <ScrollViewer Grid.Row="2"
                  IsVisible="{Binding IsDetailVisible}">
      <StackPanel Spacing="16" MaxWidth="600">

        <!-- Back button -->
        <Button Command="{Binding BackToGridCommand}"
                Padding="8,4"
                HorizontalAlignment="Left"
                BorderThickness="0"
                Background="Transparent">
          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
            <TextBlock Text="←"
                       FontSize="16"
                       Foreground="{StaticResource AccentBrush}"/>
            <TextBlock Grid.Column="1"
                       Text="Back to catalog"
                       Foreground="{StaticResource AccentBrush}"
                       FontSize="13"/>
          </Grid>
        </Button>

        <!-- Item detail card -->
        <Border Classes="Card" Padding="24">
          <StackPanel Spacing="16">

            <StackPanel Spacing="8">
              <TextBlock Text="{Binding SelectedItem.Name}"
                         FontSize="24"
                         FontWeight="Bold"
                         TextWrapping="Wrap"/>
              <TextBlock Text="{Binding SelectedItem.Category}"
                         FontSize="12"
                         Foreground="{StaticResource AccentBrush}"/>
            </StackPanel>

            <TextBlock Text="{Binding SelectedItem.Description}"
                       FontSize="13"
                       Foreground="{StaticResource TextMutedBrush}"
                       TextWrapping="Wrap"/>

            <Separator Background="{StaticResource BorderBrush}"
                       Height="1"
                       Margin="0,4"/>

            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                  RowSpacing="8">
              <TextBlock Text="Version"
                         Foreground="{StaticResource TextDimBrush}"
                         FontSize="12"
                         Grid.Row="0"/>
              <TextBlock Grid.Column="1"
                         Text="{Binding SelectedItem.Version}"
                         FontSize="12"
                         Grid.Row="0"/>

              <TextBlock Text="Developer"
                         Foreground="{StaticResource TextDimBrush}"
                         FontSize="12"
                         Grid.Row="1"/>
              <TextBlock Grid.Column="1"
                         Text="{Binding SelectedItem.Developer}"
                         FontSize="12"
                         Grid.Row="1"/>

              <TextBlock Text="Release date"
                         Foreground="{StaticResource TextDimBrush}"
                         FontSize="12"
                         Grid.Row="2"/>
              <TextBlock Grid.Column="1"
                         Text="{Binding SelectedItem.ReleaseDate}"
                         FontSize="12"
                         Grid.Row="2"/>

              <TextBlock Text="Compatibility"
                         Foreground="{StaticResource TextDimBrush}"
                         FontSize="12"
                         Grid.Row="3"/>
              <TextBlock Grid.Column="1"
                         Text="{Binding SelectedItem.Compatibility}"
                         FontSize="12"
                         Grid.Row="3"/>
            </Grid>

            <!-- Requirements -->
            <StackPanel Spacing="4"
                        IsVisible="{Binding SelectedItem.Requirements.Count, Converter={StaticResource IntToBool}}">
              <TextBlock Text="Requirements"
                         FontSize="12"
                         FontWeight="SemiBold"/>
              <ItemsControl ItemsSource="{Binding SelectedItem.Requirements}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding}"
                               FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="12,2,0,2"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <!-- Features -->
            <StackPanel Spacing="4"
                        IsVisible="{Binding SelectedItem.Features.Count, Converter={StaticResource IntToBool}}">
              <TextBlock Text="Features"
                         FontSize="12"
                         FontWeight="SemiBold"/>
              <ItemsControl ItemsSource="{Binding SelectedItem.Features}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding}"
                               FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="12,2,0,2"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Classes="Accent"
                      Padding="20,10">
                <TextBlock Text="Install"
                           FontSize="13"
                           FontWeight="SemiBold"/>
              </Button>

              <Button Padding="20,10"
                      IsEnabled="{Binding SelectedItem.DownloadUrl, Converter={StaticResource StringNotEmpty}}">
                <TextBlock Text="Download"
                           FontSize="13"/>
              </Button>
            </StackPanel>

          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

  </Grid>

</UserControl>
