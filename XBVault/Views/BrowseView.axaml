<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="XBVault.Views.BrowseView">

  <Grid RowDefinitions="Auto,Auto,*" Margin="32">

    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="0,24,0,16">
      <TextBlock Text="BROWSE"
                 Classes="PageTitle"/>
      <TextBlock Text="Discover homebrew apps and emulators from Emulation Revival"
                 Classes="Muted"
                 FontSize="14"
                 Margin="0,4,0,0"/>
    </StackPanel>

    <!-- Search + Filters -->
    <Grid Grid.Row="1"
          ColumnDefinitions="*,Auto,Auto"
          ColumnSpacing="12"
          Margin="0,0,0,16">

      <TextBox Watermark="Search catalog..."
               Text="{Binding SearchText}"
               Padding="12,8"/>

      <ComboBox Grid.Column="1"
                ItemsSource="{Binding Categories}"
                SelectedItem="{Binding SelectedCategory}"
                Width="140"
                Padding="8,6"/>

      <CheckBox Grid.Column="2"
                IsChecked="{Binding ShowExperimental}"
                Foreground="{StaticResource TextMutedBrush}"
                FontSize="12"
                VerticalAlignment="Center">
        <TextBlock Text="Show experimental"/>
      </CheckBox>
    </Grid>

    <!-- Loading -->
    <TextBlock Grid.Row="2"
               Text="Loading catalog..."
               IsVisible="{Binding IsLoading}"
               Foreground="{StaticResource TextMutedBrush}"
               FontSize="14"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>

    <!-- Empty state -->
    <StackPanel Grid.Row="2"
                IsVisible="{Binding HasItems, Converter={StaticResource BoolInverse}}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
      <TextBlock Text="No items found"
                 FontSize="16"
                 Foreground="{StaticResource TextMutedBrush}"
                 HorizontalAlignment="Center"/>
      <TextBlock Text="Adjust your search or filters"
                 FontSize="13"
                 Foreground="{StaticResource TextDimBrush}"
                 HorizontalAlignment="Center"/>
    </StackPanel>

    <!-- Catalog Grid -->
    <ListBox Grid.Row="2"
             ItemsSource="{Binding Items}"
             SelectedItem="{Binding SelectedItem}"
             BorderThickness="0"
             Background="Transparent"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             IsVisible="{Binding HasItems}">
      <ListBox.ItemsPanel>
        <ItemsPanelTemplate>
          <WrapPanel Orientation="Horizontal"/>
        </ItemsPanelTemplate>
      </ListBox.ItemsPanel>
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Classes="Card"
                  Padding="0"
                  Width="240"
                  MinHeight="220"
                  Margin="0,0,16,16"
                  Cursor="Hand">
            <Border.Styles>
              <Style Selector="Border:pointerover">
                <Setter Property="BorderBrush" Value="{StaticResource AccentDimBrush}"/>
              </Style>
            </Border.Styles>
            <Grid RowDefinitions="Auto,*">
              <Border CornerRadius="8,8,0,0"
                      Height="130"
                      Background="{StaticResource SurfaceAltBrush}"
                      HorizontalAlignment="Stretch">
                <Image Source="{Binding Thumbnail}"
                       Stretch="UniformToFill"/>
              </Border>
              <StackPanel Grid.Row="1" Spacing="6" Margin="12">
                <TextBlock Text="{Binding Name}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"/>
                <TextBlock Text="{Binding Description}"
                           FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           TextWrapping="Wrap"
                           MaxHeight="36"/>
                <TextBlock Text="{Binding Category}"
                           FontSize="10"
                           Foreground="{StaticResource AccentBrush}"
                           TextWrapping="Wrap"/>
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

  </Grid>

</UserControl>
