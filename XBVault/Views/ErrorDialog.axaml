<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="XBVault.Views.ErrorDialog"
        Classes="dialogWindow"
        Title="Error"
        Width="540" Height="420"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        WindowDecorations="None"
        Background="{StaticResource SurfaceBrush}">

  <Window.Styles>
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
    </Style>
  </Window.Styles>

  <Border BorderBrush="#447F3E" BorderThickness="2" Margin="1">
    <Grid RowDefinitions="Auto,Auto,*">

    <!-- Title Bar -->
    <Grid Height="32"
          PointerPressed="OnTitleBarPointerPressed"
          Background="{StaticResource TitleGradient}">
      <Grid.ColumnDefinitions>*,Auto</Grid.ColumnDefinitions>
      <TextBlock x:Name="TitleText"
                 Foreground="#1A1A1A"
                 FontSize="14"
                 FontWeight="Bold"
                 VerticalAlignment="Center"
                 Margin="12,0"/>
      <Button Grid.Column="1" Classes="WindowClose"
              Click="OnCloseClick" ToolTip.Tip="Close"/>
    </Grid>

    <!-- Header: Icon + Description -->
    <Border Grid.Row="1" Padding="16,16,16,8">
      <Grid ColumnDefinitions="48,*" ColumnSpacing="14">
        <Image x:Name="IconImage"
               Width="48" Height="48"
               Stretch="Uniform"
               VerticalAlignment="Top"/>
        <TextBlock x:Name="DescriptionText"
                   Grid.Column="1"
                   TextWrapping="Wrap"
                   FontSize="13"
                   Foreground="{StaticResource TextBrush}"
                   VerticalAlignment="Center"/>
      </Grid>
    </Border>

    <!-- Console area -->
    <Border Grid.Row="2" Margin="16,0,16,16"
            Background="{StaticResource SurfaceAltBrush}"
            CornerRadius="6"
            Padding="12,8">
      <Grid RowDefinitions="*,Auto">
        <ScrollViewer>
          <TextBlock x:Name="DetailsText"
                     FontFamily="{StaticResource MonoFont}"
                     FontSize="12"
                     Foreground="#2ECC71"
                     TextWrapping="Wrap"/>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,8,0,0">
          <Button x:Name="CopyBtn"
                  Classes="Accent"
                  Padding="12,6"
                  Click="OnCopyClick"
                  ToolTip.Tip="Copy error details to clipboard">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
              <Image Source="avares://XBVault/Assets/Views/ErrorDialog/errordialog-copy-20.png"
Width="20" Height="20"
                      Stretch="Uniform"/>
              <TextBlock Grid.Column="1" Text="Copy Error" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </Grid>
          </Button>
          <Button x:Name="RestartBtn"
                  Padding="12,6"
                  Click="OnRestartClick"
                  ToolTip.Tip="Restart the application">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
              <Image Source="avares://XBVault/Assets/Views/ErrorDialog/errordialog-restart-20.png"
Width="20" Height="20"
                      Stretch="Uniform"/>
              <TextBlock Grid.Column="1" Text="Restart" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </Grid>
          </Button>
          <Button Padding="12,6"
                  Click="OnCloseClick"
                  ToolTip.Tip="Close this dialog">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
<Image Source="avares://XBVault/Assets/Views/ErrorDialog/errordialog-closebtn-20.png"
 Width="20" Height="20"
                      Stretch="Uniform"/>
              <TextBlock Grid.Column="1" Text="Close" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </Grid>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    </Grid>
  </Border>

</Window>
