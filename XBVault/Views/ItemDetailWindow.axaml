<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:XBVault.ViewModels"
        xmlns:sys="using:System"
        x:Class="XBVault.Views.ItemDetailWindow"
        x:DataType="vm:BrowseViewModel"
        Title="Item Details"
        Width="540" Height="600"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        WindowDecorations="None"
        Background="{StaticResource SurfaceBrush}">

  <Window.Styles>
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
    </Style>
  </Window.Styles>

  <Border BorderBrush="#447F3E" BorderThickness="2">
    <Grid RowDefinitions="Auto,*">
    <!-- Title Bar -->
    <Grid Height="32"
          PointerPressed="OnTitleBarPointerPressed">
      <Grid.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
          <GradientStop Color="#447F3E" Offset="0"/>
          <GradientStop Color="#9ACA3C" Offset="1"/>
        </LinearGradientBrush>
      </Grid.Background>
      <Grid.ColumnDefinitions>*,Auto</Grid.ColumnDefinitions>
      <TextBlock Text="Item Details"
                 Foreground="#1A1A1A"
                 FontSize="14"
                 FontWeight="Bold"
                 VerticalAlignment="Center"
                 Margin="12,0"/>
      <Button Grid.Column="1"
              Width="32" Height="32"
              Padding="0"
              BorderThickness="0"
              Click="OnCloseClick"
              Cursor="Hand"
              ToolTip.Tip="Close">
        <Image Source="avares://XBVault/Assets/Views/ItemDetailWindow/itemdetail-close-20.png"
Width="20" Height="20"
                        Stretch="Uniform"/>
        <Button.Styles>
          <Style Selector="Button">
            <Setter Property="Background" Value="Transparent"/>
          </Style>
          <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#CC3333"/>
          </Style>
          <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#CC3333"/>
          </Style>
        </Button.Styles>
      </Button>
    </Grid>

    <!-- Content -->
    <Border Grid.Row="1"
            BorderThickness="0">
      <Grid RowDefinitions="Auto,*,Auto" Margin="16">

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="{Binding SelectedItem.Name}"
                   FontSize="20"
                   FontWeight="Bold"
                   TextWrapping="Wrap"
                   Margin="0,0,0,4"/>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="1" Margin="0,16">
          <StackPanel Spacing="16">

            <TextBlock Text="{Binding SelectedItem.Category}"
                       FontSize="12"
                       Foreground="{StaticResource AccentBrush}"/>

            <Border CornerRadius="8"
                    Background="{StaticResource SurfaceAltBrush}"
                    Height="200"
                    HorizontalAlignment="Stretch">
              <Image Source="{Binding SelectedItem.Thumbnail}"
                     Stretch="UniformToFill"/>
            </Border>

            <TextBlock Text="{Binding SelectedItem.Description}"
                       FontSize="13"
                       Foreground="{StaticResource TextMutedBrush}"
                       TextWrapping="Wrap"/>

            <Separator Background="{StaticResource BorderBrush}"
                       Height="1"/>

            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                  RowSpacing="8">
              <TextBlock Text="Version"
                         Foreground="{StaticResource TextDimBrush}"
                         FontSize="12"
                         Grid.Row="0"/>
              <TextBlock Grid.Column="1"
                         Text="{Binding SelectedItem.Version}"
                         FontSize="12"
                         Grid.Row="0"/>

              <TextBlock Text="Developer"
                         Foreground="{StaticResource TextDimBrush}"
                         FontSize="12"
                         Grid.Row="1"/>
              <TextBlock Grid.Column="1"
                         Text="{Binding SelectedItem.Developer}"
                         FontSize="12"
                         Grid.Row="1"/>

              <TextBlock Text="Release date"
                         Foreground="{StaticResource TextDimBrush}"
                         FontSize="12"
                         Grid.Row="2"/>
              <TextBlock Grid.Column="1"
                         Text="{Binding SelectedItem.ReleaseDate}"
                         FontSize="12"
                         Grid.Row="2"/>

              <TextBlock Text="Compatibility"
                         Foreground="{StaticResource TextDimBrush}"
                         FontSize="12"
                         Grid.Row="3"/>
              <TextBlock Grid.Column="1"
                         Text="{Binding SelectedItem.Compatibility}"
                         FontSize="12"
                         Grid.Row="3"/>
            </Grid>

            <StackPanel Spacing="4"
                        IsVisible="{Binding SelectedItem.Requirements.Count, Converter={StaticResource IntToBool}}">
              <TextBlock Text="Requirements"
                         FontSize="12"
                         FontWeight="SemiBold"/>
              <ItemsControl ItemsSource="{Binding SelectedItem.Requirements}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="sys:String">
                    <TextBlock Text="{Binding}"
                               FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="12,2,0,2"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <StackPanel Spacing="4"
                        IsVisible="{Binding SelectedItem.Features.Count, Converter={StaticResource IntToBool}}">
              <TextBlock Text="Features"
                         FontSize="12"
                         FontWeight="SemiBold"/>
              <ItemsControl ItemsSource="{Binding SelectedItem.Features}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="sys:String">
                    <TextBlock Text="{Binding}"
                               FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="12,2,0,2"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>

            <StackPanel Spacing="6"
                        IsVisible="{Binding IsInstalling}">
              <ProgressBar Value="{Binding InstallProgress}"
                           Maximum="1"
                           Height="4"
                           Foreground="{StaticResource AccentBrush}"/>
              <TextBlock Text="{Binding InstallStatus}"
                         FontSize="11"
                         Foreground="{StaticResource TextMutedBrush}"/>
            </StackPanel>

          </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Spacing="8" Margin="0,4,0,0">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Classes="Accent"
                    Padding="20,10"
                    Command="{Binding InstallSelectedCommand}"
                    IsEnabled="{Binding IsInstalling, Converter={StaticResource BoolInverse}}">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                <Image Source="avares://XBVault/Assets/Views/ItemDetailWindow/itemdetail-install-20.png"
                       Width="20" Height="20"
                       Stretch="Uniform"/>
                <TextBlock Grid.Column="1" Text="Install"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
              </Grid>
            </Button>

            <Button Padding="20,10"
                    IsEnabled="{Binding SelectedItem.DownloadUrl, Converter={StaticResource StringNotEmpty}}">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                <Image Source="avares://XBVault/Assets/Views/ItemDetailWindow/itemdetail-download-20.png"
                       Width="20" Height="20"
                       Stretch="Uniform"/>
                <TextBlock Grid.Column="1" Text="Download"
                           FontSize="13"
                           VerticalAlignment="Center"/>
              </Grid>
            </Button>

            <Button Padding="16,10"
                    Command="{Binding CheckInstalledCommand}"
                    IsEnabled="{Binding IsCheckingInstalled, Converter={StaticResource BoolInverse}}">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                <Image Source="avares://XBVault/Assets/Views/ItemDetailWindow/itemdetail-check-20.png"
                       Width="20" Height="20"
                       Stretch="Uniform"/>
                <TextBlock Grid.Column="1" Text="Check Installed"
                           FontSize="12"
                           VerticalAlignment="Center"/>
              </Grid>
            </Button>
          </StackPanel>

          <Border Padding="10,8"
                  CornerRadius="4"
                  Background="{StaticResource SurfaceAltBrush}"
                  IsVisible="{Binding InstalledVersion, Converter={StaticResource StringNotEmpty}}">
            <TextBlock FontSize="12">
              <Run Text="Status:" FontWeight="SemiBold"/>
              <Run Text="{Binding InstalledVersion}"/>
            </TextBlock>
          </Border>
        </StackPanel>

      </Grid>
    </Border>
    </Grid>
  </Border>

</Window>
