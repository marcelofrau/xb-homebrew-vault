<UserControl xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:vm="using:XBVault.ViewModels"
              xmlns:models="using:XBVault.Models"
              x:Class="XBVault.Views.InstalledView"
              x:DataType="vm:InstalledViewModel">

  <Grid RowDefinitions="Auto,Auto,*" Margin="32">

    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="0,24,0,16">
      <TextBlock Text="INSTALLED"
                 Classes="PageTitle"/>
      <TextBlock Text="Manage apps and emulators installed on your Xbox"
                 Classes="Muted"
                 FontSize="14"
                 Margin="0,4,0,0"/>
    </StackPanel>

    <!-- Toolbar -->
    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                Spacing="8"
                Margin="0,0,0,16">
      <Button Command="{Binding RefreshPackagesCommand}"
              Padding="12,8">
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
<Image Source="avares://XBVault/Assets/Views/InstalledView/installed-refresh-20.png"
                  Width="20" Height="20"
                  Stretch="Uniform"/>
          <TextBlock Grid.Column="1"
                     Text="Refresh"
                     FontSize="13"
                     VerticalAlignment="Center"/>
        </Grid>
      </Button>

      <Button Command="{Binding UninstallSelectedCommand}"
              Classes="Danger"
              Padding="12,8"
              IsEnabled="{Binding IsPackageSelected}">
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
<Image Source="avares://XBVault/Assets/Views/InstalledView/installed-uninstall-20.png"
                  Width="20" Height="20"
                  Stretch="Uniform"/>
          <TextBlock Grid.Column="1"
                     Text="Uninstall"
                     FontSize="13"
                     VerticalAlignment="Center"/>
        </Grid>
      </Button>
    </StackPanel>

    <!-- Loading -->
    <StackPanel Grid.Row="2"
                IsVisible="{Binding IsLoading}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
      <Image x:Name="SpinnerImage"
             Source="avares://XBVault/Assets/Views/InstalledView/installed-spinner-48.png"
             Width="48" Height="48"
             Stretch="Uniform"
             HorizontalAlignment="Center"
             RenderTransformOrigin="50% 50%">
        <Image.RenderTransform>
          <RotateTransform Angle="0"/>
        </Image.RenderTransform>
      </Image>
      <ProgressBar IsIndeterminate="True"
                   Width="200"
                   Foreground="{StaticResource AccentBrush}"/>
      <TextBlock Text="Loading packages..."
                 Foreground="{StaticResource TextMutedBrush}"
                 FontSize="13"
                 HorizontalAlignment="Center"/>
    </StackPanel>

    <!-- Status message -->
    <TextBlock Grid.Row="2"
               Text="{Binding StatusMessage}"
               IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmpty}}"
               Foreground="{StaticResource TextMutedBrush}"
               FontSize="13"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>

    <!-- Package list -->
    <ListBox Grid.Row="2"
             ItemsSource="{Binding Packages}"
             SelectedItem="{Binding SelectedPackage}"
             BorderThickness="0"
             Background="Transparent"
             IsVisible="{Binding HasPackages}">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="models:InstalledPackage">
          <Border Classes="Card"
                  Padding="16"
                  Margin="0,0,0,8"
                  Cursor="Hand">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
              <!-- Icon placeholder -->
              <Border Width="40" Height="40"
                      CornerRadius="4"
                      Background="{StaticResource SurfaceAltBrush}">
                <TextBlock Text="P"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
              </Border>

              <!-- Info -->
              <StackPanel Grid.Column="1"
                          VerticalAlignment="Center"
                          Spacing="2">
                <TextBlock Text="{Binding Name}"
                           FontSize="14"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding FullName}"
                           FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           TextTrimming="CharacterEllipsis"/>
                <StackPanel Orientation="Horizontal" Spacing="12">
                  <TextBlock Text="{Binding Version}"
                             FontSize="11"
                             Foreground="{StaticResource TextDimBrush}"/>
                  <TextBlock Text="{Binding InstalledSizeBytes, StringFormat={}{0:N0} bytes}"
                             FontSize="11"
                             Foreground="{StaticResource TextDimBrush}"/>
                </StackPanel>
              </StackPanel>

              <!-- Arrow -->
              <TextBlock Grid.Column="2"
                         Text="›"
                         FontSize="20"
                         Foreground="{StaticResource TextDimBrush}"
                         VerticalAlignment="Center"/>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

  </Grid>

</UserControl>
