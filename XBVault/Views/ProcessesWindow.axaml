<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:XBVault.ViewModels"
        xmlns:models="using:XBVault.Models"
        x:Class="XBVault.Views.ProcessesWindow"
        Classes="dialogWindow"
        x:DataType="vm:ProcessesViewModel"
        Title="Processes"
        WindowStartupLocation="CenterOwner"
        Width="720" Height="540"
        CanResize="False"
        ShowInTaskbar="False"
        WindowDecorations="None"
        Background="{StaticResource SurfaceBrush}"
        Cursor="{Binding Cursor}">
  <Window.Styles>
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
    </Style>
  </Window.Styles>
  <Border BorderBrush="#447F3E" BorderThickness="2" Margin="1">
    <Grid RowDefinitions="Auto,*">
      <Grid Height="32" PointerPressed="OnTitleBarPointerPressed"
            Background="{StaticResource TitleGradient}">
        <Grid.ColumnDefinitions>*,Auto</Grid.ColumnDefinitions>
        <TextBlock Text="Processes"
                   Foreground="#1A1A1A" FontSize="14" FontWeight="Bold"
                   VerticalAlignment="Center" Margin="12,0"/>
        <Button Grid.Column="1" Classes="WindowClose"
                Click="OnCloseClick" ToolTip.Tip="Close"/>
      </Grid>
      <Border Grid.Row="1" Padding="20">
        <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12">
          <TextBlock Grid.Row="0"
                     Text="Running processes on Xbox"
                     FontSize="11"
                     Foreground="{StaticResource TextMutedBrush}"/>

          <TextBox Grid.Row="1"
                   Text="{Binding FilterText}"
                    PlaceholderText="Filter processes..."
                    
                   FontSize="13"
                   Padding="10,8"/>

          <Border Grid.Row="2"
                  Background="{StaticResource SurfaceAltBrush}"
                  CornerRadius="6" Padding="0">
            <Grid RowDefinitions="Auto,*">
              <Border Padding="0" CornerRadius="6,6,0,0"
                      Background="{StaticResource TitleGradient}">
                <Border.Styles>
                  <Style Selector="Button">
                    <Setter Property="Background" Value="Transparent"/>
                  </Style>
                  <Style Selector="Button:pointerover">
                    <Setter Property="Background" Value="#33447F3E"/>
                  </Style>
                  <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="Background" Value="#33447F3E"/>
                  </Style>
                </Border.Styles>
                <Grid ColumnDefinitions="60,*,90,90,80" ColumnSpacing="10">
                  <Button Command="{Binding SortByCommand}" CommandParameter="ProcessId"
                          Background="Transparent" BorderThickness="0"
                          Padding="8,6" HorizontalContentAlignment="Stretch" Cursor="Hand">
                    <TextBlock FontSize="11" FontWeight="Bold" Foreground="#1A1A1A">
                      <Run Text="PID"/><Run Text="{Binding SortPidIndicator}"/>
                    </TextBlock>
                  </Button>
                  <Button Grid.Column="1" Command="{Binding SortByCommand}" CommandParameter="ImageName"
                          Background="Transparent" BorderThickness="0"
                          Padding="8,6" HorizontalContentAlignment="Stretch" Cursor="Hand">
                    <TextBlock FontSize="11" FontWeight="Bold" Foreground="#1A1A1A">
                      <Run Text="Image Name"/><Run Text="{Binding SortImageNameIndicator}"/>
                    </TextBlock>
                  </Button>
                  <Button Grid.Column="2" Command="{Binding SortByCommand}" CommandParameter="MemoryUsage"
                          Background="Transparent" BorderThickness="0"
                          Padding="8,6" HorizontalContentAlignment="Stretch" Cursor="Hand">
                    <TextBlock FontSize="11" FontWeight="Bold" Foreground="#1A1A1A" TextAlignment="Right">
                      <Run Text="Memory"/><Run Text="{Binding SortMemoryIndicator}"/>
                    </TextBlock>
                  </Button>
                  <Button Grid.Column="3" Command="{Binding SortByCommand}" CommandParameter="CpuUsage"
                          Background="Transparent" BorderThickness="0"
                          Padding="8,6" HorizontalContentAlignment="Stretch" Cursor="Hand">
                    <TextBlock FontSize="11" FontWeight="Bold" Foreground="#1A1A1A" TextAlignment="Right">
                      <Run Text="CPU"/><Run Text="{Binding SortCpuIndicator}"/>
                    </TextBlock>
                  </Button>
                  <Button Grid.Column="4" Command="{Binding SortByCommand}" CommandParameter="UserName"
                          Background="Transparent" BorderThickness="0"
                          Padding="8,6" HorizontalContentAlignment="Stretch" Cursor="Hand">
                    <TextBlock FontSize="11" FontWeight="Bold" Foreground="#1A1A1A" TextAlignment="Right">
                      <Run Text="User"/><Run Text="{Binding SortUserIndicator}"/>
                    </TextBlock>
                  </Button>
                </Grid>
              </Border>
              <ScrollViewer Grid.Row="1">
                <ListBox ItemsSource="{Binding Processes}"
                         SelectedItem="{Binding SelectedProcess}"
                         BorderThickness="0" Background="Transparent">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:ProcessInfo">
                      <Border Padding="8,6">
                        <Grid ColumnDefinitions="60,*,90,90,80" ColumnSpacing="10">
                          <TextBlock Text="{Binding ProcessId}" FontSize="11"
                                     Foreground="{StaticResource TextDimBrush}"/>
                          <TextBlock Grid.Column="1" Text="{Binding ImageName}"
                                     FontSize="12" FontWeight="SemiBold"/>
                          <TextBlock Grid.Column="2" Text="{Binding MemoryDisplay}"
                                     FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                     TextAlignment="Right"/>
                          <TextBlock Grid.Column="3"
                                     Text="{Binding CpuDisplay}"
                                     FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                     TextAlignment="Right"/>
                          <TextBlock Grid.Column="4"
                                     Text="{Binding UserName}"
                                     FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                     TextAlignment="Right" Margin="0,0,8,0"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </ScrollViewer>
            </Grid>
          </Border>

          <Grid Grid.Row="3" ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
            <Button Grid.Column="0" Command="{Binding RefreshCommand}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource BoolInverse}}"
                    Padding="14,8">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                <Image Source="avares://XBVault/Assets/Views/ProcessesWindow/processes-refresh-20.png"
                       Width="20" Height="20" Stretch="Uniform"/>
                <TextBlock Grid.Column="1" Text="Refresh" VerticalAlignment="Center"/>
              </Grid>
            </Button>
            <Button Grid.Column="1" Command="{Binding KillSelectedCommand}"
                    IsEnabled="{Binding IsProcessSelected}"
                    Background="{StaticResource CardBgBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    Padding="14,8">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                <Image Source="avares://XBVault/Assets/Views/ProcessesWindow/processes-kill-20.png"
                       Width="20" Height="20" Stretch="Uniform"/>
                <TextBlock Grid.Column="1" Text="Kill Selected" VerticalAlignment="Center"/>
              </Grid>
            </Button>
            <TextBlock Grid.Column="2"
                       IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmpty}}"
                       Text="{Binding StatusMessage}"
                       Foreground="{StaticResource DangerBrush}"
                       FontSize="12" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="8,0,0,0"/>
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>
