<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:XBVault.ViewModels"
        xmlns:v="using:XBVault.Views"
         x:Class="XBVault.MainWindow"
         x:DataType="vm:MainViewModel"
         x:Name="Root"
        Title="XB Homebrew Vault"
        Width="1140" Height="800"
        WindowStartupLocation="CenterScreen"
        Icon="avares://XBVault/Assets/Views/MainWindow/mainwindow-app.png"
        Background="{StaticResource BgBrush}"
        WindowDecorations="None">

  <Window.Styles>
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
    </Style>

    <Style Selector="Button.SidebarBtn">
      <Style.Resources>
        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#332F333A"/>
        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#552F333A"/>
      </Style.Resources>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="Padding" Value="0,10"/>
      <Setter Property="Foreground" Value="#CCC"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
  </Window.Styles>

  <Border BorderBrush="#447F3E" BorderThickness="2">
    <Grid RowDefinitions="32,*" ColumnDefinitions="220,*">

    <!-- Title Bar -->
    <Grid Grid.ColumnSpan="2" Height="32"
          PointerPressed="OnTitleBarPointerPressed">
      <Grid.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
          <GradientStop Color="#447F3E" Offset="0"/>
          <GradientStop Color="#9ACA3C" Offset="1"/>
        </LinearGradientBrush>
      </Grid.Background>
      <Grid.ColumnDefinitions>*,Auto</Grid.ColumnDefinitions>
      <TextBlock Text="XB Homebrew Vault"
                 Foreground="#1A1A1A"
                 FontSize="14"
                 FontWeight="Bold"
                 VerticalAlignment="Center"
                 Margin="12,0"/>
      <Button Grid.Column="1" Width="32" Height="32"
              Padding="0"
              BorderThickness="0" Click="OnCloseClick"
              Cursor="Hand"
              ToolTip.Tip="Close">
        <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-close-20.png"
Width="20" Height="20"
                Stretch="Uniform"/>
        <Button.Styles>
          <Style Selector="Button">
            <Setter Property="Background" Value="Transparent"/>
          </Style>
          <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#CC3333"/>
          </Style>
          <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#CC3333"/>
          </Style>
        </Button.Styles>
      </Button>
    </Grid>

    <!-- Sidebar -->
    <Border Grid.Row="1" Grid.Column="0">
      <Border.Background>
        <ImageBrush Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-sidebarbg.png"
                    Stretch="UniformToFill"/>
      </Border.Background>
      <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- Brand -->
        <Border Padding="16,20,16,16"
                Grid.Row="0">
          <StackPanel HorizontalAlignment="Center">
            <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-xbox-80.png"
                   Width="80" Height="80"
                   Stretch="Uniform"
                   Margin="0,0,0,8"
                   HorizontalAlignment="Center"/>
            <TextBlock Text="XB HOMEBREW"
                       Classes="BrandTitle"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       LetterSpacing="2"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="VAULT"
                       Classes="BrandTitle"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}"
                       LetterSpacing="3"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Nav Items (Blades) -->
        <ListBox Grid.Row="1"
                 BorderThickness="0"
                 Background="Transparent"
                 SelectedIndex="{Binding SelectedTab}"
                 SelectionMode="Single">
          <ListBoxItem Tag="Browse" Padding="16,10">
             <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
              <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-browse-32.png"
                     Width="32" Height="32"
                     Stretch="Uniform"/>
              <TextBlock Text="BROWSE"
                         Grid.Column="1"
                         VerticalAlignment="Center"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TextMutedBrush}"
                         LetterSpacing="1"/>
            </Grid>
          </ListBoxItem>
          <ListBoxItem Tag="Installed" Padding="16,10">
             <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
              <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-installed-32.png"
                     Width="32" Height="32"
                     Stretch="Uniform"/>
              <TextBlock Text="INSTALLED"
                         Grid.Column="1"
                         VerticalAlignment="Center"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TextMutedBrush}"
                         LetterSpacing="1"/>
            </Grid>
          </ListBoxItem>
          <ListBoxItem Tag="FileExplorer" Padding="16,10">
             <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
              <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-fileexplorer-32.png"
                     Width="32" Height="32"
                     Stretch="Uniform"/>
              <TextBlock Text="FILE EXPLORER"
                         Grid.Column="1"
                         VerticalAlignment="Center"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TextMutedBrush}"
                         LetterSpacing="1"/>
            </Grid>
          </ListBoxItem>
          <ListBoxItem Tag="Tools" Padding="16,10">
             <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
              <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-tools-32.png"
                     Width="32" Height="32"
                     Stretch="Uniform"/>
              <TextBlock Text="TOOLS"
                         Grid.Column="1"
                         VerticalAlignment="Center"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TextMutedBrush}"
                         LetterSpacing="1"/>
            </Grid>
          </ListBoxItem>
          <ListBoxItem Tag="Settings" Padding="16,10">
             <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
              <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-settings-32.png"
                     Width="32" Height="32"
                     Stretch="Uniform"/>
              <TextBlock Text="SETTINGS"
                         Grid.Column="1"
                         VerticalAlignment="Center"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TextMutedBrush}"
                         LetterSpacing="1"/>
            </Grid>
          </ListBoxItem>
          <ListBoxItem Tag="Logs" Padding="16,10">
             <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
              <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-logs-32.png"
                     Width="32" Height="32"
                     Stretch="Uniform"/>
              <TextBlock Text="LOGS"
                         Grid.Column="1"
                         VerticalAlignment="Center"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TextMutedBrush}"
                         LetterSpacing="1"/>
            </Grid>
          </ListBoxItem>
        </ListBox>

        <!-- ER Logo -->
        <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-erlogo.png"
               Grid.Row="2"
               Width="140"
               Height="40"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               Margin="0,0,0,8"/>

        <!-- Connection status + Connect + About -->
        <StackPanel Grid.Row="3" Spacing="4" Margin="16,0,16,16">

          <!-- Connect button -->
          <Button Classes="SidebarBtn"
                  HorizontalAlignment="Stretch"
                  FontWeight="SemiBold"
                  Command="{Binding ConnectCommand}"
                  IsVisible="{Binding IsXboxConnected, Converter={StaticResource BoolInverse}}">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
              <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-connect-32.png"
                     Width="32" Height="32"
                     Stretch="Uniform"
                     VerticalAlignment="Center"/>
              <TextBlock Grid.Column="1"
                          Text="CONNECT"
                          VerticalAlignment="Center"/>
            </Grid>
          </Button>

          <!-- Disconnect button -->
          <Button Classes="SidebarBtn"
                  HorizontalAlignment="Stretch"
                  FontWeight="SemiBold"
                  Command="{Binding DisconnectCommand}"
                  IsVisible="{Binding IsXboxConnected}">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
              <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-disconnect-32.png"
                     Width="32" Height="32"
                     Stretch="Uniform"
                     VerticalAlignment="Center"/>
              <TextBlock Grid.Column="1"
                          Text="DISCONNECT"
                          VerticalAlignment="Center"/>
            </Grid>
          </Button>

          <!-- About button -->
          <Button Classes="SidebarBtn"
                  HorizontalAlignment="Stretch"
                  FontWeight="SemiBold"
                  Command="{Binding OpenAboutCommand}">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
              <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-about-32.png"
                     Width="32" Height="32"
                     Stretch="Uniform"
                     VerticalAlignment="Center"/>
              <TextBlock Grid.Column="1"
                          Text="ABOUT"
                          VerticalAlignment="Center"/>
            </Grid>
          </Button>


        </StackPanel>

      </Grid>
    </Border>

    <!-- Content Area + Status Bar -->
    <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
            Grid.Column="1"
            Padding="0">
      <Grid RowDefinitions="*,28">
        <Carousel x:Name="ViewCarousel"
                  SelectedIndex="{Binding SelectedTab}">
          <Carousel.PageTransition>
            <CrossFade Duration="0:0:0.3"/>
          </Carousel.PageTransition>
        </Carousel>

        <!-- Status Bar -->
        <Border Grid.Row="1" Background="#151515" Padding="12,0">
          <Grid ColumnDefinitions="Auto,Auto,*">
            <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-status-notconfigured-16.png"
                   Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"
                   IsVisible="{Binding IsNotConfigured}"/>
            <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-status-disconnected-16.png"
                   Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"
                   IsVisible="{Binding IsDisconnected}"/>
            <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-status-connected-16.png"
                   Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"
                   IsVisible="{Binding IsXboxConnected}"/>
            <TextBlock Grid.Column="1"
                        Text="{Binding ConnectionStatusText}"
                        Foreground="#AAA"
                        FontSize="11"
                        VerticalAlignment="Center"
                        Margin="6,0,0,0"/>
            <TextBlock Grid.Column="2"
                        x:Name="VersionText"
                        Foreground="#555"
                        FontSize="11"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"/>
          </Grid>
        </Border>
      </Grid>
    </Border>

    </Grid>
  </Border>

</Window>
