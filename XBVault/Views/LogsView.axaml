<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:XBVault.ViewModels"
              xmlns:converters="using:XBVault.Converters"
              xmlns:svc="using:XBVault.Services"
              x:Class="XBVault.Views.LogsView"
              x:DataType="vm:LogsViewModel">

  <UserControl.Resources>
    <converters:LogLevelToBrushConverter x:Key="LevelToBrush"/>
  </UserControl.Resources>

  <Grid Margin="16">
    <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="6" Padding="12">
      <ScrollViewer>
        <ItemsControl ItemsSource="{Binding Logs}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="svc:LogEntry">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4" Margin="0,1">
                <TextBlock Text="{Binding Marker}"
                           FontSize="13"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding Message}"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="12"
                           TextWrapping="NoWrap"
                           VerticalAlignment="Center"
                           Foreground="{Binding Level, Converter={StaticResource LevelToBrush}}"/>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>
  </Grid>

</UserControl>
