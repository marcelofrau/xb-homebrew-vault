<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="using:Avalonia.Controls.Converters"
        xmlns:controls="using:XBVault.Controls">

  <Styles.Resources>
    <!-- Xbox 360 Blades Palette -->
    <Color x:Key="BladesBg">#0D1117</Color>
    <Color x:Key="BladesSurface">#1A1D23</Color>
    <Color x:Key="BladesSurfaceAlt">#252830</Color>
    <Color x:Key="BladesSurfaceHover">#2F333A</Color>
    <Color x:Key="BladesAccent">#9ACA3C</Color>
    <Color x:Key="BladesAccentDim">#6B8F2A</Color>
    <Color x:Key="BladesAccentGlow">#B5E665</Color>
    <Color x:Key="BladesAccentHoverDark">#44681A</Color>
    <Color x:Key="BladesText">#F0F0F0</Color>
    <Color x:Key="BladesTextMuted">#8B8D91</Color>
    <Color x:Key="BladesTextDim">#5A5C60</Color>
    <Color x:Key="BladesDanger">#E74C3C</Color>
    <Color x:Key="BladesSuccess">#2ECC71</Color>
    <Color x:Key="BladesWarning">#F39C12</Color>
    <Color x:Key="BladesYellow">#FFD700</Color>
    <Color x:Key="BladesBorder">#2A2D33</Color>
    <Color x:Key="BladesCardBg">#1E2128</Color>
    <Color x:Key="BladesSidebarBg">#0F1F10</Color>
    <Color x:Key="BladesInputBg">#0F1F0F</Color>
    <Color x:Key="BladesInputBorder">#4A7A20</Color>
    <Color x:Key="BladesInputBorderHover">#6B8F2A</Color>
    <Color x:Key="BladesComboBoxBg">#7AA82E</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BladesBg}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource BladesSurface}"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource BladesSurfaceAlt}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource BladesAccent}"/>
    <SolidColorBrush x:Key="AccentDimBrush" Color="{StaticResource BladesAccentDim}"/>
    <SolidColorBrush x:Key="AccentGlowBrush" Color="{StaticResource BladesAccentGlow}"/>
    <SolidColorBrush x:Key="AccentHoverDarkBrush" Color="{StaticResource BladesAccentHoverDark}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource BladesText}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource BladesTextMuted}"/>
    <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource BladesTextDim}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource BladesDanger}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource BladesSuccess}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource BladesWarning}"/>
    <SolidColorBrush x:Key="YellowBrush" Color="{StaticResource BladesYellow}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BladesBorder}"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource BladesCardBg}"/>
    <SolidColorBrush x:Key="SidebarBgBrush" Color="{StaticResource BladesSidebarBg}"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource BladesSurfaceHover}"/>
    <SolidColorBrush x:Key="InputBgBrush" Color="{StaticResource BladesInputBg}"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="{StaticResource BladesInputBorder}"/>
    <SolidColorBrush x:Key="InputBorderHoverBrush" Color="{StaticResource BladesInputBorderHover}"/>
    <SolidColorBrush x:Key="ComboBoxBgBrush" Color="{StaticResource BladesComboBoxBg}"/>

    <!-- Title gradient -->
    <LinearGradientBrush x:Key="TitleGradient" StartPoint="0%,0%" EndPoint="100%,0%">
      <GradientStop Color="#447F3E" Offset="0"/>
      <GradientStop Color="#9ACA3C" Offset="1"/>
    </LinearGradientBrush>

    <!-- Fonts -->
    <FontFamily x:Key="TitleFont">avares://XBVault/Assets/Fonts/Oxanium-700.ttf#Oxanium</FontFamily>
    <FontFamily x:Key="BodyFont">avares://XBVault/Assets/Fonts/Oxanium-400.ttf#Oxanium</FontFamily>
    <FontFamily x:Key="MonoFont">avares://XBVault/Assets/Fonts/ProFontWindowsNerdFont-Regular.ttf#ProFontWindows Nerd Font, Consolas, Courier New, Courier, monospace</FontFamily>

    <!-- Fluent theme overrides -->
    <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="{StaticResource BladesComboBoxBg}"/>
    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3A6B2E"/>
    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#F0F0F0"/>

    <!-- TreeView -->
    <SolidColorBrush x:Key="TreeViewItemForeground" Color="{StaticResource BladesText}"/>
    <SolidColorBrush x:Key="TreeViewItemLineColor" Color="#3A3D43"/>
    <SolidColorBrush x:Key="TreeViewItemBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="TreeViewItemBackgroundPointerOver" Color="{StaticResource BladesSurfaceHover}"/>
    <SolidColorBrush x:Key="TreeViewItemBackgroundSelected" Color="{StaticResource BladesSurfaceAlt}"/>
    <SolidColorBrush x:Key="TreeViewItemBackgroundSelectedPointerOver" Color="{StaticResource BladesSurfaceHover}"/>
    <converters:MarginMultiplierConverter Indent="16" Left="True" x:Key="TreeViewItemLeftMarginConverter"/>
    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#45803E"/>
    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#3A6B2E"/>
    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#6B8F2A"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#6B8F2A"/>
    <SolidColorBrush x:Key="ButtonForeground" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#5A5C60"/>
    <SolidColorBrush x:Key="RegionBrush" Color="{StaticResource BladesSurface}"/>
    <Color x:Key="RegionColor">#1A1D23</Color>
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="{StaticResource BladesSurface}"/>
    <Color x:Key="ContentBackgroundColor">#1A1D23</Color>
    <SolidColorBrush x:Key="SystemControlBackgroundAltHighBrush" Color="{StaticResource BladesSurface}"/>
    <SolidColorBrush x:Key="SystemControlPageBackgroundAltHighBrush" Color="{StaticResource BladesSurface}"/>
    <SolidColorBrush x:Key="SystemControlPageBackgroundChromeLowBrush" Color="{StaticResource BladesSurface}"/>

    <!-- TreeViewItem theme with connector lines -->
    <ControlTheme x:Key="{x:Type TreeViewItem}" TargetType="TreeViewItem"
                  BasedOn="{StaticResource {x:Type TreeViewItem}}">
      <Setter Property="ClipToBounds" Value="False"/>
      <Setter Property="MinHeight" Value="28"/>
      <Setter Property="Template">
        <ControlTemplate>
          <Grid RowDefinitions="Auto,*">
            <!-- Vertical connector line -->
            <Rectangle Name="LineVert"
                       Grid.RowSpan="2"
                       Width="1"
                       Margin="{TemplateBinding Level, Mode=OneWay, Converter={StaticResource TreeViewItemLeftMarginConverter}}"
                       HorizontalAlignment="Left"
                       Fill="{StaticResource TreeViewItemLineColor}"
                       RenderTransform="TranslateX(5px)"
                       ZIndex="99"/>

            <Border Name="PART_LayoutRoot"
                    Classes="TreeViewItemLayoutRoot"
                    Focusable="True"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    MinHeight="{TemplateBinding MinHeight}"
                    Margin="4,2"
                    TemplatedControl.IsTemplateFocusTarget="True">
              <Grid Name="PART_Header"
                    ColumnDefinitions="Auto,*"
                    Margin="{TemplateBinding Level, Mode=OneWay, Converter={StaticResource TreeViewItemLeftMarginConverter}}">
                <Panel Name="PART_ExpandCollapseChevronContainer"
                       Width="35">
                  <StackPanel Orientation="Horizontal">
                    <!-- Horizontal connector line -->
                    <Border Name="LineHoriz"
                            Width="8" Height="16"
                            Margin="0,0,4,0"
                            VerticalAlignment="Top"
                            BorderBrush="{StaticResource TreeViewItemLineColor}"
                            BorderThickness="1,0,0,1"
                            CornerRadius="0,0,0,8"
                            RenderTransform="Translate(0px, -2px)"/>
                    <ToggleButton Name="PART_ExpandCollapseChevron"
                                  Width="12"
                                  Height="12"
                                  Theme="{StaticResource FluentTreeViewExpandCollapseChevron}"
                                  Focusable="False"
                                  IsChecked="{TemplateBinding IsExpanded, Mode=TwoWay}"/>
                  </StackPanel>
                </Panel>
                <ContentPresenter Name="PART_HeaderPresenter"
                                  Grid.Column="1"
                                  Focusable="False"
                                  Background="Transparent"
                                  Content="{TemplateBinding Header}"
                                  ContentTemplate="{TemplateBinding HeaderTemplate}"
                                  HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                  VerticalAlignment="{TemplateBinding VerticalAlignment}"
                                  Margin="{TemplateBinding Padding}"/>
              </Grid>
            </Border>

            <ItemsPresenter Name="PART_ItemsPresenter"
                            Grid.Row="1"
                            IsVisible="{TemplateBinding IsExpanded}"
                            ItemsPanel="{TemplateBinding ItemsPanel}"/>
          </Grid>
        </ControlTemplate>
      </Setter>

      <!-- Last child: shorten connector so it doesn't extend below -->
      <Style Selector="^[(controls|TreeViewItemProperties.IsLastChild)=True] /template/ Rectangle#LineVert">
        <Setter Property="Height" Value="10"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
      </Style>

      <!-- Root level (drives): no connector lines -->
      <Style Selector="^[Level=0] /template/ Rectangle#LineVert">
        <Setter Property="IsVisible" Value="False"/>
      </Style>
      <Style Selector="^[Level=0] /template/ Border#LineHoriz">
        <Setter Property="IsVisible" Value="False"/>
      </Style>
      <!-- Root chevron offset to align with child levels -->
      <Style Selector="^[Level=0] /template/ Panel#PART_ExpandCollapseChevronContainer">
        <Setter Property="Margin" Value="12,0,0,0"/>
        <Setter Property="Width" Value="23"/>
      </Style>
    </ControlTheme>
  </Styles.Resources>

  <!-- Window -->
  <Style Selector="Window">
    <Setter Property="Background" Value="{StaticResource BgBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
  </Style>

  <Style Selector="Window.dialogWindow">
    <Setter Property="Opacity" Value="0"/>
    <Setter Property="Transitions">
      <Setter.Value>
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
        </Transitions>
      </Setter.Value>
    </Setter>
    <Setter Property="(controls:DialogFadeBehavior.EnableDialogFade)" Value="True"/>
  </Style>

  <!-- Text -->
  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
  </Style>

  <Style Selector="TextBlock.Muted">
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
  </Style>

  <Style Selector="TextBlock.Accent">
    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
  </Style>

  <!-- ToolTip -->
  <Style Selector="ToolTip">
    <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
  </Style>

  <!-- Button -->
  <Style Selector="Button">
    <Style.Resources>
      <SolidColorBrush x:Key="ButtonForeground" Color="#F0F0F0"/>
      <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#F0F0F0"/>
      <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#F0F0F0"/>
      <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#5A5C60"/>
      <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#2F333A"/>
      <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#45803E"/>
      <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#6B8F2A"/>
      <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#9ACA3C"/>
    </Style.Resources>
    <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Padding" Value="12,6"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
    <Setter Property="Transitions">
      <Setter.Value>
        <Transitions>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
        </Transitions>
      </Setter.Value>
    </Setter>
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="RenderTransform" Value="scale(1.02)"/>
  </Style>

  <Style Selector="Button:pressed">
    <Setter Property="RenderTransform" Value="scale(0.98)"/>
  </Style>

  <Style Selector="Button.Accent">
    <Style.Resources>
      <SolidColorBrush x:Key="ButtonForeground" Color="#1A1A1A"/>
      <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#F0F0F0"/>
      <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#F0F0F0"/>
      <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#5A5C60"/>
      <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#45803E"/>
      <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3A6B2E"/>
      <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#6B8F2A"/>
      <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#3A6B2E"/>
    </Style.Resources>
    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource AccentHoverDarkBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource AccentDimBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="4"/>
  </Style>

  <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="#45803E"/>
  </Style>

  <Style Selector="Button.Accent:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="#45803E"/>
  </Style>

  <Style Selector="Button.Accent:pointerover /template/ Border">
    <Setter Property="BorderBrush" Value="#9ACA3C"/>
  </Style>

  <Style Selector="Button.Accent:pressed /template/ Border">
    <Setter Property="BorderBrush" Value="#3A6B2E"/>
  </Style>

  <Style Selector="Button.Accent /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Foreground" Value="#1A1A1A"/>
  </Style>
  <Style Selector="Button.Accent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Foreground" Value="#F0F0F0"/>
  </Style>
  <Style Selector="Button.Accent:disabled /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Foreground" Value="#5A5C60"/>
  </Style>

  <Style Selector="Button:disabled /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Foreground" Value="#5A5C60"/>
  </Style>

  <Style Selector="Button.Accent TextBlock">
    <Setter Property="Foreground" Value="#1A1A1A"/>
  </Style>
  <Style Selector="Button.Accent:pointerover TextBlock">
    <Setter Property="Foreground" Value="#F0F0F0"/>
  </Style>
  <Style Selector="Button.Accent:disabled TextBlock">
    <Setter Property="Foreground" Value="#5A5C60"/>
  </Style>
  <Style Selector="Button:disabled TextBlock">
    <Setter Property="Foreground" Value="#5A5C60"/>
  </Style>

  <Style Selector="Button.Danger">
    <Style.Resources>
      <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
      <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
      <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#E74C3C"/>
      <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#C0392B"/>
    </Style.Resources>
    <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
    <Setter Property="Foreground" Value="White"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>

  <!-- Window close button -->
  <Style Selector="Button.WindowClose">
    <Setter Property="Width" Value="32"/>
    <Setter Property="Height" Value="32"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Content">
      <Template>
        <Image Source="avares://XBVault/Assets/Icons/close-20.png"
               Width="20" Height="20" Stretch="Uniform"/>
      </Template>
    </Setter>
  </Style>
  <Style Selector="Button.WindowClose:pointerover">
    <Setter Property="Background" Value="#CC3333"/>
  </Style>
  <Style Selector="Button.WindowClose:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="#CC3333"/>
  </Style>

    <!-- MenuFlyout -->
  <Style Selector="MenuFlyoutPresenter">
    <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="5"/>
    <Setter Property="Padding" Value="4"/>
  </Style>

  <Style Selector="MenuItem">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="Padding" Value="10,6"/>
    <Setter Property="CornerRadius" Value="3"/>
  </Style>

  <Style Selector="MenuItem:pointerover /template/ Border">
    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
  </Style>

  <Style Selector="MenuItem:pointerover /template/ ContentPresenter#PART_Header">
    <Setter Property="Foreground" Value="#1A1A1A"/>
  </Style>

  <Style Selector="MenuItem:focus-visible /template/ Border">
    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
  </Style>
  <Style Selector="MenuItem:focus-visible /template/ ContentPresenter#PART_Header">
    <Setter Property="Foreground" Value="#1A1A1A"/>
  </Style>

  <Style Selector="MenuItem:focus /template/ ContentPresenter#PART_Header">
    <Setter Property="Foreground" Value="#1A1A1A"/>
  </Style>
  <Style Selector="MenuItem:focus /template/ Border">
    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
  </Style>

  <Style Selector="MenuFlyoutPresenter MenuItem:focus-visible /template/ Border">
    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
  </Style>
  <Style Selector="MenuFlyoutPresenter MenuItem:focus-visible /template/ ContentPresenter#PART_Header">
    <Setter Property="Foreground" Value="White"/>
  </Style>

  <Style Selector="MenuItem:pressed /template/ Border">
    <Setter Property="Background" Value="{StaticResource AccentHoverDarkBrush}"/>
  </Style>

  <Style Selector="MenuItem:disabled">
    <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
  </Style>

  <!-- TextBox -->
  <Style Selector="TextBox">


    <Style.Resources>
      <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#0F1F0F"/>
      <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#2A2D33"/>
      <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#F0F0F0"/>
      <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#0F1F0F"/>
      <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#B5E665"/>
      <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#B5E665"/>
      <Thickness x:Key="TextControlBorderThemeThicknessFocused">1</Thickness>
      <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#8B8D91"/>
    </Style.Resources>
    <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Padding" Value="10,5"/>
    <Setter Property="FontSize" Value="14"/>
    <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
  </Style>

  <Style Selector="TextBox /template/ TextBlock#PART_Placeholder">
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
  </Style>

  <Style Selector="TextBox /template/ TextBlock#PART_FloatingPlaceholder">
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
  </Style>

  <Style Selector="TextBox:error /template/ Border#PART_BorderElement">
    <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
    <Setter Property="BorderThickness" Value="1.5"/>
  </Style>

  <!-- CheckBox -->
  <Style Selector="CheckBox">
    <Setter Property="Foreground" Value="White"/>
  </Style>
  <Style Selector="CheckBox:pointerover">
    <Setter Property="Foreground" Value="#9ACA3C"/>
  </Style>
  <Style Selector="CheckBox TextBlock">
    <Setter Property="Foreground" Value="White"/>
  </Style>
  <Style Selector="CheckBox:pointerover TextBlock">
    <Setter Property="Foreground" Value="#9ACA3C"/>
  </Style>

  <!-- RadioButton -->
  <Style Selector="RadioButton">
    <Setter Property="Foreground" Value="White"/>
  </Style>
  <Style Selector="RadioButton:pointerover">
    <Setter Property="Foreground" Value="#9ACA3C"/>
  </Style>
  <Style Selector="RadioButton TextBlock">
    <Setter Property="Foreground" Value="White"/>
  </Style>
  <Style Selector="RadioButton:pointerover TextBlock">
    <Setter Property="Foreground" Value="#9ACA3C"/>
  </Style>

  <!-- ListBox -->
  <Style Selector="ListBox">
    <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="4"/>
  </Style>

  <Style Selector="ListBoxItem">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
    <Setter Property="Transitions">
      <Setter.Value>
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
        </Transitions>
      </Setter.Value>
    </Setter>
  </Style>

  <Style Selector="ListBoxItem:pointerover">
    <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
  </Style>

  <Style Selector="ListBoxItem:selected">
    <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
  </Style>

  <!-- Card style -->
  <Style Selector="Border.Card">
    <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
  </Style>

  <!-- Section headers -->
  <Style Selector="TextBlock.PageTitle">
    <Setter Property="FontSize" Value="28"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="FontFamily" Value="{StaticResource TitleFont}"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
  </Style>

  <Style Selector="TextBlock.SectionHeader">
    <Setter Property="FontSize" Value="16"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
  </Style>

  <Style Selector="TextBlock.BrandTitle">
    <Setter Property="FontFamily" Value="{StaticResource TitleFont}"/>
    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
  </Style>

  <!-- ComboBox -->
  <Style Selector="ComboBox">
    <Setter Property="Background" Value="{StaticResource ComboBoxBgBrush}"/>
    <Setter Property="Foreground" Value="#0D1117"/>
  </Style>

  <Style Selector="ComboBox ScrollViewer">
    <Setter Property="Background" Value="{StaticResource ComboBoxBgBrush}"/>
  </Style>

  <Style Selector="ComboBoxItem">
    <Setter Property="Background" Value="{StaticResource ComboBoxBgBrush}"/>
    <Setter Property="Foreground" Value="#0D1117"/>
  </Style>

  <Style Selector="ComboBoxItem:pointerover">
    <Setter Property="Background" Value="#3D6B1F"/>
  </Style>

  <Style Selector="ComboBoxItem:selected">
    <Setter Property="Background" Value="{StaticResource AccentGlowBrush}"/>
  </Style>

  <!-- NumericUpDown -->
  <Style Selector="NumericUpDown">
    <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="ButtonSpinnerLocation" Value="Right"/>
  </Style>
  <Style Selector="NumericUpDown:pointerover">
    <Setter Property="BorderBrush" Value="{StaticResource InputBorderHoverBrush}"/>
  </Style>
  <Style Selector="NumericUpDown:focus-within">
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
  </Style>
  <Style Selector="NumericUpDown /template/ RepeatButton">
    <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
  </Style>
  <Style Selector="NumericUpDown /template/ RepeatButton:pointerover">
    <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
  </Style>

</Styles>
