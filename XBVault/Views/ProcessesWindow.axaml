<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:XBVault.ViewModels"
        xmlns:models="using:XBVault.Models"
        x:Class="XBVault.Views.ProcessesWindow"
        x:DataType="vm:ProcessesViewModel"
        Title="Processes"
        WindowStartupLocation="CenterOwner"
        Width="720" Height="540"
        CanResize="False"
        ShowInTaskbar="False"
        WindowDecorations="None"
        Background="{StaticResource SurfaceBrush}">
  <Window.Styles>
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
    </Style>
  </Window.Styles>
  <Border BorderBrush="#447F3E" BorderThickness="2">
    <Grid RowDefinitions="Auto,*">
      <Grid Height="32" PointerPressed="OnTitleBarPointerPressed">
        <Grid.Background>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
            <GradientStop Color="#447F3E" Offset="0"/>
            <GradientStop Color="#9ACA3C" Offset="1"/>
          </LinearGradientBrush>
        </Grid.Background>
        <Grid.ColumnDefinitions>*,Auto</Grid.ColumnDefinitions>
        <TextBlock Text="Processes"
                   Foreground="#1A1A1A" FontSize="14" FontWeight="Bold"
                   VerticalAlignment="Center" Margin="12,0"/>
        <Button Grid.Column="1" Width="32" Height="32" Padding="0"
                BorderThickness="0" Click="OnCloseClick" Cursor="Hand"
                ToolTip.Tip="Close">
          <Image Source="avares://XBVault/Assets/Views/ConnectionWindow/connection-close-20.png"
                 Width="20" Height="20" Stretch="Uniform"/>
          <Button.Styles>
            <Style Selector="Button"><Setter Property="Background" Value="Transparent"/></Style>
            <Style Selector="Button:pointerover"><Setter Property="Background" Value="#CC3333"/></Style>
            <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter"><Setter Property="Background" Value="#CC3333"/></Style>
          </Button.Styles>
        </Button>
      </Grid>
      <Border Grid.Row="1" Padding="20">
        <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12">
          <TextBlock Grid.Row="0"
                     Text="Running processes on Xbox"
                     FontSize="11"
                     Foreground="{StaticResource TextMutedBrush}"/>

          <TextBox Grid.Row="1"
                   Text="{Binding FilterText}"
                    PlaceholderText="Filter processes..."
                    
                   FontSize="13"
                   Padding="10,8"/>

          <Border Grid.Row="2"
                  Background="{StaticResource SurfaceAltBrush}"
                  CornerRadius="6" Padding="0">
            <ScrollViewer>
              <ListBox ItemsSource="{Binding Processes}"
                       SelectedItem="{Binding SelectedProcess}"
                       BorderThickness="0" Background="Transparent">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="models:ProcessInfo">
                    <Border Padding="8,6">
                      <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                        <TextBlock Text="{Binding ProcessId}" FontSize="11"
                                   Foreground="{StaticResource TextDimBrush}" Width="60"/>
                        <TextBlock Grid.Column="1" Text="{Binding ImageName}"
                                   FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="{Binding MemoryDisplay}"
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   Width="90" TextAlignment="Right"/>
                        <TextBlock Grid.Column="3"
                                   Text="{Binding CpuUsage, StringFormat='{}{0:F1}%'}"
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   Width="60" TextAlignment="Right"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </ScrollViewer>
          </Border>

          <Grid Grid.Row="3" ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
            <Button Grid.Column="0" Command="{Binding RefreshCommand}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource BoolInverse}}"
                    Padding="14,8">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                <Image Source="avares://XBVault/Assets/Views/ProcessesWindow/processes-refresh-20.png"
                       Width="20" Height="20" Stretch="Uniform"/>
                <TextBlock Grid.Column="1" Text="Refresh" VerticalAlignment="Center"/>
              </Grid>
            </Button>
            <Button Grid.Column="1" Command="{Binding KillSelectedCommand}"
                    IsEnabled="{Binding IsProcessSelected}"
                    Padding="14,8">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                <Image Source="avares://XBVault/Assets/Views/ProcessesWindow/processes-kill-20.png"
                       Width="20" Height="20" Stretch="Uniform"/>
                <TextBlock Grid.Column="1" Text="Kill Selected" VerticalAlignment="Center"/>
              </Grid>
            </Button>
            <TextBlock Grid.Column="2"
                       IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmpty}}"
                       Text="{Binding StatusMessage}"
                       Foreground="{StaticResource DangerBrush}"
                       FontSize="12" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="8,0,0,0"/>
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>
