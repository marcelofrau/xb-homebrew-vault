<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="XBVault.Views.BrowseView">

  <Grid RowDefinitions="Auto,Auto,*" Margin="32">

    <!-- Header Row: title left, checkbox + refresh right -->
    <Grid Grid.Row="0"
          ColumnDefinitions="*,Auto"
          Margin="0,24,0,16">
      <StackPanel>
        <TextBlock Text="BROWSE"
                   Classes="PageTitle"/>
        <TextBlock Text="Discover homebrew apps and emulators from Emulation Revival"
                   Classes="Muted"
                   FontSize="14"
                   Margin="0,4,0,0"/>
      </StackPanel>
      <StackPanel Grid.Column="1"
                  Spacing="8"
                  VerticalAlignment="Center">
        <CheckBox IsChecked="{Binding ShowExperimental}"
                  Foreground="{StaticResource TextMutedBrush}"
                  FontSize="12"
                  HorizontalAlignment="Right">
          <TextBlock Text="Show experimental"/>
        </CheckBox>
        <Button Command="{Binding RefreshCatalogCommand}"
                Padding="10,6"
                HorizontalAlignment="Right"
                ToolTip.Tip="Force re-download catalog">
          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
            <Image Source="avares://XBVault/Assets/Icons/refresh.ico"
                   Width="16" Height="16"
                   Stretch="Uniform"/>
            <TextBlock Grid.Column="1" Text="Refresh" FontSize="13"/>
          </Grid>
        </Button>
      </StackPanel>
    </Grid>

    <!-- Search + Category -->
    <Grid Grid.Row="1"
          ColumnDefinitions="5*,*"
          ColumnSpacing="12"
          Margin="0,0,0,16">
      <TextBox Watermark="Search catalog..."
               Text="{Binding SearchText}"
               Padding="12,8"/>
      <ComboBox Grid.Column="1"
                ItemsSource="{Binding Categories}"
                SelectedItem="{Binding SelectedCategory}"
                HorizontalAlignment="Stretch"
                Padding="8,6"/>
    </Grid>

    <!-- Loading -->
    <StackPanel Grid.Row="2"
                IsVisible="{Binding IsLoading}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
      <Image x:Name="SpinnerImage"
             Source="avares://XBVault/Assets/Images/cd.png"
             Width="48" Height="48"
             Stretch="Uniform"
             HorizontalAlignment="Center"
             RenderTransformOrigin="50% 50%">
        <Image.RenderTransform>
          <RotateTransform Angle="0"/>
        </Image.RenderTransform>
      </Image>
      <ProgressBar IsIndeterminate="True"
                   Width="200"
                   Foreground="{StaticResource AccentBrush}"/>
      <TextBlock Text="Loading catalog..."
                 Foreground="{StaticResource TextMutedBrush}"
                 FontSize="13"
                 HorizontalAlignment="Center"/>
    </StackPanel>

    <!-- Empty state -->
    <StackPanel Grid.Row="2"
                IsVisible="{Binding HasItems, Converter={StaticResource BoolInverse}}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
      <TextBlock Text="No items found"
                 FontSize="16"
                 Foreground="{StaticResource TextMutedBrush}"
                 HorizontalAlignment="Center"/>
      <TextBlock Text="Adjust your search or filters"
                 FontSize="13"
                 Foreground="{StaticResource TextDimBrush}"
                 HorizontalAlignment="Center"/>
    </StackPanel>

    <!-- Catalog Grid -->
    <ListBox Grid.Row="2"
             ItemsSource="{Binding Items}"
             SelectedItem="{Binding SelectedItem}"
             BorderThickness="0"
             Background="Transparent"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             IsVisible="{Binding HasItems}">
      <ListBox.ItemsPanel>
        <ItemsPanelTemplate>
          <WrapPanel Orientation="Horizontal"/>
        </ItemsPanelTemplate>
      </ListBox.ItemsPanel>
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Classes="Card"
                  Padding="0"
                  Width="240"
                  MinHeight="220"
                  Margin="0,0,16,16"
                  Cursor="Hand">
            <Border.Styles>
              <Style Selector="Border:pointerover">
                <Setter Property="BorderBrush" Value="{StaticResource AccentDimBrush}"/>
              </Style>
            </Border.Styles>
            <Grid RowDefinitions="Auto,*">
              <Border CornerRadius="8,8,0,0"
                      Height="130"
                      Background="{StaticResource SurfaceAltBrush}"
                      HorizontalAlignment="Stretch">
                <Image Source="{Binding Thumbnail}"
                       Stretch="UniformToFill"/>
              </Border>
              <StackPanel Grid.Row="1" Spacing="6" Margin="12">
                <TextBlock Text="{Binding Name}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"/>
                <TextBlock Text="{Binding Description}"
                           FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           TextWrapping="Wrap"
                           MaxHeight="36"/>
                <TextBlock Text="{Binding Category}"
                           FontSize="10"
                           Foreground="{StaticResource AccentBrush}"
                           TextWrapping="Wrap"/>
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

  </Grid>

</UserControl>
