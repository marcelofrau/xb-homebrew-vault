{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug (XBVault)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/XBVault/bin/Debug/net8.0/XBVault.exe",
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "externalTerminal",
      "stopAtEntry": false,
      "requireExactSource": false
    },
    {
      "name": "Run (no debug)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/XBVault/bin/Debug/net8.0/XBVault.exe",
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "externalTerminal",
      "stopAtEntry": false,
      "noDebug": true
    },
    {
      "name": "Debug (Attach)",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}"
    }
  ]
}
