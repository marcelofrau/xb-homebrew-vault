<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="XBVault.Views.ConnectionWindow"
        Title="Xbox Connection"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        CanResize="False"
        ShowInTaskbar="False"
        SystemDecorations="None"
        Background="{StaticResource SurfaceBrush}">

  <Window.Styles>
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
    </Style>
  </Window.Styles>

  <Border BorderBrush="#447F3E" BorderThickness="2">
    <Grid RowDefinitions="Auto,*">
    <!-- Title Bar -->
    <Grid Height="32"
          PointerPressed="OnTitleBarPointerPressed">
      <Grid.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
          <GradientStop Color="#447F3E" Offset="0"/>
          <GradientStop Color="#9ACA3C" Offset="1"/>
        </LinearGradientBrush>
      </Grid.Background>
      <Grid.ColumnDefinitions>*,Auto</Grid.ColumnDefinitions>
      <TextBlock Text="Xbox Connection"
                 Foreground="#1A1A1A"
                 FontSize="14"
                 FontWeight="Bold"
                 VerticalAlignment="Center"
                 Margin="12,0"/>
      <Button Grid.Column="1"
              Width="32" Height="32"
              Padding="0"
              BorderThickness="0"
              Click="OnCloseClick"
              Cursor="Hand"
              ToolTip.Tip="Close">
        <Image Source="avares://XBVault/Assets/Icons/close.ico"
               Width="16" Height="16"
               Stretch="Uniform"/>
        <Button.Styles>
          <Style Selector="Button">
            <Setter Property="Background" Value="Transparent"/>
          </Style>
          <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#CC3333"/>
          </Style>
          <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#CC3333"/>
          </Style>
        </Button.Styles>
      </Button>
    </Grid>

    <!-- Content -->
    <Border Grid.Row="1"
            BorderThickness="0">
      <StackPanel Margin="12" Spacing="8">

        <!-- Banner -->
        <Image Source="avares://XBVault/Assets/Images/connection-banner.png"
               Stretch="None"
               HorizontalAlignment="Center"/>

        <TextBlock Text="Establish Xbox connection"
                   FontSize="14"
                   FontWeight="Bold"
                   Foreground="{StaticResource AccentBrush}"
                   HorizontalAlignment="Center"/>

        <!-- Details -->
        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
          <TextBlock Text="Connect to Xbox Developer Mode via Device Portal"
                     FontSize="12"
                     Foreground="{StaticResource TextMutedBrush}"/>
          <TextBlock Grid.Row="1"
                     Text="Status:"
                     FontSize="12"
                     Foreground="{StaticResource TextDimBrush}"/>
          <TextBlock Grid.Row="1" Grid.Column="1"
                     Text="{Binding Progress, StringFormat={}{0:P0}}"
                     FontSize="12"
                     HorizontalAlignment="Right"/>
        </Grid>

        <!-- Terminal output -->
        <Border Background="{StaticResource SurfaceAltBrush}"
                CornerRadius="6"
                Padding="8,6"
                Height="135"
                MaxHeight="135"
                MinHeight="135">
          <ScrollViewer x:Name="OutputScroll">
            <ItemsControl ItemsSource="{Binding OutputLines}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}"
                             FontFamily="{StaticResource MonoFont}"
                             FontSize="13"
                             Foreground="#2ECC71"
                             TextWrapping="NoWrap"/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>

        <!-- Buttons + Progress -->
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <ProgressBar Grid.Column="0"
                       IsIndeterminate="True"
                       Height="4"
                       VerticalAlignment="Center"
                       IsVisible="{Binding IsRunning}"
                       Foreground="{StaticResource AccentBrush}"
                       Margin="0,0,8,0"/>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="OnCloseClick" Padding="10,6" MaxWidth="100"/>
            <Button x:Name="ConnectBtn"
                    Classes="Accent"
                    Content="Connect"
                    Command="{Binding ConnectCommand}"
                    IsEnabled="{Binding IsRunning, Converter={StaticResource BoolInverse}}"
                    Padding="10,6" MaxWidth="120"/>
          </StackPanel>
        </Grid>

      </StackPanel>
    </Border>
    </Grid>
  </Border>

</Window>
