<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Styles.Resources>
    <!-- Xbox 360 Blades Palette -->
    <Color x:Key="BladesBg">#0D1117</Color>
    <Color x:Key="BladesSurface">#1A1D23</Color>
    <Color x:Key="BladesSurfaceAlt">#252830</Color>
    <Color x:Key="BladesSurfaceHover">#2F333A</Color>
    <Color x:Key="BladesAccent">#9ACA3C</Color>
    <Color x:Key="BladesAccentDim">#6B8F2A</Color>
    <Color x:Key="BladesAccentGlow">#B5E665</Color>
    <Color x:Key="BladesAccentHoverDark">#44681A</Color>
    <Color x:Key="BladesText">#F0F0F0</Color>
    <Color x:Key="BladesTextMuted">#8B8D91</Color>
    <Color x:Key="BladesTextDim">#5A5C60</Color>
    <Color x:Key="BladesDanger">#E74C3C</Color>
    <Color x:Key="BladesSuccess">#2ECC71</Color>
    <Color x:Key="BladesWarning">#F39C12</Color>
    <Color x:Key="BladesYellow">#FFD700</Color>
    <Color x:Key="BladesBorder">#2A2D33</Color>
    <Color x:Key="BladesCardBg">#1E2128</Color>
    <Color x:Key="BladesSidebarBg">#0F1F10</Color>
    <Color x:Key="BladesInputBg">#0F1F0F</Color>
    <Color x:Key="BladesInputBorder">#4A7A20</Color>
    <Color x:Key="BladesInputBorderHover">#6B8F2A</Color>
    <Color x:Key="BladesComboBoxBg">#7AA82E</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BladesBg}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource BladesSurface}"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource BladesSurfaceAlt}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource BladesAccent}"/>
    <SolidColorBrush x:Key="AccentDimBrush" Color="{StaticResource BladesAccentDim}"/>
    <SolidColorBrush x:Key="AccentGlowBrush" Color="{StaticResource BladesAccentGlow}"/>
    <SolidColorBrush x:Key="AccentHoverDarkBrush" Color="{StaticResource BladesAccentHoverDark}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource BladesText}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource BladesTextMuted}"/>
    <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource BladesTextDim}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource BladesDanger}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource BladesSuccess}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource BladesWarning}"/>
    <SolidColorBrush x:Key="YellowBrush" Color="{StaticResource BladesYellow}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BladesBorder}"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource BladesCardBg}"/>
    <SolidColorBrush x:Key="SidebarBgBrush" Color="{StaticResource BladesSidebarBg}"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource BladesSurfaceHover}"/>
    <SolidColorBrush x:Key="InputBgBrush" Color="{StaticResource BladesInputBg}"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="{StaticResource BladesInputBorder}"/>
    <SolidColorBrush x:Key="InputBorderHoverBrush" Color="{StaticResource BladesInputBorderHover}"/>
    <SolidColorBrush x:Key="ComboBoxBgBrush" Color="{StaticResource BladesComboBoxBg}"/>

    <!-- Fonts -->
    <FontFamily x:Key="TitleFont">avares://XBVault/Assets/Fonts/Oxanium-700.ttf#Oxanium</FontFamily>
    <FontFamily x:Key="BodyFont">avares://XBVault/Assets/Fonts/Oxanium-400.ttf#Oxanium</FontFamily>
    <FontFamily x:Key="MonoFont">avares://XBVault/Assets/Fonts/ProFontWindowsNerdFont-Regular.ttf#ProFontWindows Nerd Font, Consolas, Courier New, Courier, monospace</FontFamily>

    <!-- Fluent theme overrides -->
    <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="{StaticResource BladesComboBoxBg}"/>
    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3A6B2E"/>
    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#45803E"/>
    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#3A6B2E"/>
    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#6B8F2A"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#6B8F2A"/>
    <SolidColorBrush x:Key="ButtonForeground" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#5A5C60"/>
    <SolidColorBrush x:Key="RegionBrush" Color="{StaticResource BladesSurface}"/>
    <Color x:Key="RegionColor">#1A1D23</Color>
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="{StaticResource BladesSurface}"/>
    <Color x:Key="ContentBackgroundColor">#1A1D23</Color>
    <SolidColorBrush x:Key="SystemControlBackgroundAltHighBrush" Color="{StaticResource BladesSurface}"/>
    <SolidColorBrush x:Key="SystemControlPageBackgroundAltHighBrush" Color="{StaticResource BladesSurface}"/>
    <SolidColorBrush x:Key="SystemControlPageBackgroundChromeLowBrush" Color="{StaticResource BladesSurface}"/>
  </Styles.Resources>

  <!-- Window -->
  <Style Selector="Window">
    <Setter Property="Background" Value="{StaticResource BgBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
  </Style>

  <!-- Text -->
  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
  </Style>

  <Style Selector="TextBlock.Muted">
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
  </Style>

  <Style Selector="TextBlock.Accent">
    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
  </Style>

  <!-- ToolTip -->
  <Style Selector="ToolTip">
    <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
  </Style>

  <!-- Button -->
  <Style Selector="Button">
    <Style.Resources>
      <SolidColorBrush x:Key="ButtonForeground" Color="#F0F0F0"/>
      <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#F0F0F0"/>
      <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#F0F0F0"/>
      <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#5A5C60"/>
      <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#2F333A"/>
      <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#45803E"/>
      <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#6B8F2A"/>
      <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#9ACA3C"/>
    </Style.Resources>
    <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Padding" Value="12,6"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>

  <Style Selector="Button.Accent">
    <Style.Resources>
      <SolidColorBrush x:Key="ButtonForeground" Color="#1A1A1A"/>
      <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#F0F0F0"/>
      <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#F0F0F0"/>
      <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#5A5C60"/>
      <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#45803E"/>
      <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3A6B2E"/>
      <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#6B8F2A"/>
      <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#3A6B2E"/>
    </Style.Resources>
    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource AccentHoverDarkBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource AccentDimBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="4"/>
  </Style>

  <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="#45803E"/>
  </Style>

  <Style Selector="Button.Accent:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="#45803E"/>
  </Style>

  <Style Selector="Button.Accent:pointerover /template/ Border">
    <Setter Property="BorderBrush" Value="#9ACA3C"/>
  </Style>

  <Style Selector="Button.Accent:pressed /template/ Border">
    <Setter Property="BorderBrush" Value="#3A6B2E"/>
  </Style>

  <Style Selector="Button.Accent /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Foreground" Value="#1A1A1A"/>
  </Style>
  <Style Selector="Button.Accent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Foreground" Value="#F0F0F0"/>
  </Style>
  <Style Selector="Button.Accent:disabled /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Foreground" Value="#5A5C60"/>
  </Style>

  <Style Selector="Button:disabled /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Foreground" Value="#5A5C60"/>
  </Style>

  <Style Selector="Button.Accent TextBlock">
    <Setter Property="Foreground" Value="#1A1A1A"/>
  </Style>
  <Style Selector="Button.Accent:pointerover TextBlock">
    <Setter Property="Foreground" Value="#F0F0F0"/>
  </Style>
  <Style Selector="Button.Accent:disabled TextBlock">
    <Setter Property="Foreground" Value="#5A5C60"/>
  </Style>
  <Style Selector="Button:disabled TextBlock">
    <Setter Property="Foreground" Value="#5A5C60"/>
  </Style>

  <Style Selector="Button.Danger">
    <Style.Resources>
      <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
      <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
      <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#E74C3C"/>
      <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#C0392B"/>
    </Style.Resources>
    <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
    <Setter Property="Foreground" Value="White"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>

  <!-- TextBox -->
  <Style Selector="TextBox">
    <Style.Resources>
      <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#0F1F0F"/>
      <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#2A2D33"/>
      <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#F0F0F0"/>
      <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#0F1F0F"/>
      <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#B5E665"/>
      <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#B5E665"/>
      <Thickness x:Key="TextControlBorderThemeThicknessFocused">1</Thickness>
      <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#8B8D91"/>
    </Style.Resources>
    <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Padding" Value="10,5"/>
    <Setter Property="FontSize" Value="14"/>
    <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
  </Style>

  <Style Selector="TextBox /template/ TextBlock#PART_Placeholder">
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
  </Style>

  <Style Selector="TextBox /template/ TextBlock#PART_FloatingPlaceholder">
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
  </Style>

  <Style Selector="TextBox:error /template/ Border#PART_BorderElement">
    <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
    <Setter Property="BorderThickness" Value="1.5"/>
  </Style>

  <!-- CheckBox -->
  <Style Selector="CheckBox">
    <Setter Property="Foreground" Value="White"/>
  </Style>
  <Style Selector="CheckBox:pointerover">
    <Setter Property="Foreground" Value="#9ACA3C"/>
  </Style>
  <Style Selector="CheckBox TextBlock">
    <Setter Property="Foreground" Value="White"/>
  </Style>
  <Style Selector="CheckBox:pointerover TextBlock">
    <Setter Property="Foreground" Value="#9ACA3C"/>
  </Style>

  <!-- RadioButton -->
  <Style Selector="RadioButton">
    <Setter Property="Foreground" Value="White"/>
  </Style>
  <Style Selector="RadioButton:pointerover">
    <Setter Property="Foreground" Value="#9ACA3C"/>
  </Style>
  <Style Selector="RadioButton TextBlock">
    <Setter Property="Foreground" Value="White"/>
  </Style>
  <Style Selector="RadioButton:pointerover TextBlock">
    <Setter Property="Foreground" Value="#9ACA3C"/>
  </Style>

  <!-- ListBox -->
  <Style Selector="ListBox">
    <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="4"/>
  </Style>

  <Style Selector="ListBoxItem">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
  </Style>

  <Style Selector="ListBoxItem:pointerover">
    <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
  </Style>

  <Style Selector="ListBoxItem:selected">
    <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
  </Style>

  <!-- Card style -->
  <Style Selector="Border.Card">
    <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
  </Style>

  <!-- Section headers -->
  <Style Selector="TextBlock.PageTitle">
    <Setter Property="FontSize" Value="28"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="FontFamily" Value="{StaticResource TitleFont}"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
  </Style>

  <Style Selector="TextBlock.SectionHeader">
    <Setter Property="FontSize" Value="16"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
  </Style>

  <Style Selector="TextBlock.BrandTitle">
    <Setter Property="FontFamily" Value="{StaticResource TitleFont}"/>
    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
  </Style>

  <!-- ComboBox -->
  <Style Selector="ComboBox">
    <Setter Property="Background" Value="{StaticResource ComboBoxBgBrush}"/>
    <Setter Property="Foreground" Value="#0D1117"/>
  </Style>

  <Style Selector="ComboBox ScrollViewer">
    <Setter Property="Background" Value="{StaticResource ComboBoxBgBrush}"/>
  </Style>

  <Style Selector="ComboBoxItem">
    <Setter Property="Background" Value="{StaticResource ComboBoxBgBrush}"/>
    <Setter Property="Foreground" Value="#0D1117"/>
  </Style>

  <Style Selector="ComboBoxItem:pointerover">
    <Setter Property="Background" Value="#3D6B1F"/>
  </Style>

  <Style Selector="ComboBoxItem:selected">
    <Setter Property="Background" Value="{StaticResource AccentGlowBrush}"/>
  </Style>

  <!-- NumericUpDown -->
  <Style Selector="NumericUpDown">
    <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="ButtonSpinnerLocation" Value="Right"/>
  </Style>
  <Style Selector="NumericUpDown:pointerover">
    <Setter Property="BorderBrush" Value="{StaticResource InputBorderHoverBrush}"/>
  </Style>
  <Style Selector="NumericUpDown:focus-within">
    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
  </Style>
  <Style Selector="NumericUpDown /template/ RepeatButton">
    <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
  </Style>
  <Style Selector="NumericUpDown /template/ RepeatButton:pointerover">
    <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
  </Style>

</Styles>
