<UserControl xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:vm="using:XBVault.ViewModels"
              xmlns:models="using:XBVault.Models"
              xmlns:controls="using:XBVault.Controls"
              x:Class="XBVault.Views.BrowseView"
              x:DataType="vm:BrowseViewModel">

  <Grid RowDefinitions="Auto,Auto,*" Margin="32">

    <!-- Header Row: title left, checkbox + refresh right -->
    <Grid Grid.Row="0"
          ColumnDefinitions="*,Auto"
          Margin="0,24,0,16">
      <StackPanel>
        <TextBlock Text="BROWSE"
                   Classes="PageTitle"/>
        <TextBlock Text="Discover homebrew apps and emulators from Emulation Revival"
                   Classes="Muted"
                   FontSize="14"
                   Margin="0,4,0,0"/>
      </StackPanel>
          <StackPanel Grid.Column="1"
                  Spacing="8"
                  VerticalAlignment="Center">
        <CheckBox IsChecked="{Binding ShowExperimental}"
                  Foreground="{StaticResource TextMutedBrush}"
                  FontSize="12"
                  HorizontalAlignment="Right">
          <TextBlock Text="Show experimental"/>
        </CheckBox>
        <StackPanel Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Right">
          <Button Command="{Binding OpenCustomInstallCommand}"
                  Padding="10,6"
                  ToolTip.Tip="Install a package from a local file or URL">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
              <Image Source="avares://XBVault/Assets/Views/ToolsView/tools-install-20.png"
                     Width="20" Height="20"
                     Stretch="Uniform"/>
              <TextBlock Grid.Column="1" Text="Custom Install" FontSize="13" VerticalAlignment="Center"/>
            </Grid>
          </Button>
          <Button Command="{Binding RefreshCatalogCommand}"
                  Padding="10,6"
                  ToolTip.Tip="Force re-download catalog">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
              <Image Source="avares://XBVault/Assets/Views/BrowseView/browse-refresh-20.png"
                     Width="20" Height="20"
                     Stretch="Uniform"/>
              <TextBlock Grid.Column="1" Text="Refresh" FontSize="13" VerticalAlignment="Center"/>
            </Grid>
          </Button>
        </StackPanel>
      </StackPanel>
    </Grid>

    <!-- Search + Category -->
    <Grid Grid.Row="1"
          ColumnDefinitions="5*,*"
          ColumnSpacing="12"
          Margin="0,0,0,16">
      <TextBox PlaceholderText="Search catalog..."
               Text="{Binding SearchText}"
               Padding="12,8"/>
      <ComboBox Grid.Column="1"
                ItemsSource="{Binding Categories}"
                SelectedItem="{Binding SelectedCategory}"
                HorizontalAlignment="Stretch"
                Padding="12,8"
                Background="#45803E"
                Foreground="#2A2A2A">
        <ComboBox.Styles>
          <Style Selector="ComboBox">
            <Style.Resources>
              <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="#45803E"/>
              <SolidColorBrush x:Key="ComboBoxBackground" Color="#45803E"/>
              <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="#4D8F45"/>
              <SolidColorBrush x:Key="ComboBoxBackgroundPressed" Color="#3A6B34"/>
            </Style.Resources>
          </Style>
        </ComboBox.Styles>
      </ComboBox>
    </Grid>

    <!-- Loading -->
    <StackPanel Grid.Row="2"
                IsVisible="{Binding IsLoading}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
      <Image x:Name="SpinnerImage"
             Source="avares://XBVault/Assets/Views/BrowseView/browse-spinner-48.png"
             Width="48" Height="48"
             Stretch="Uniform"
             HorizontalAlignment="Center"
             RenderTransformOrigin="50% 50%">
        <Image.RenderTransform>
          <RotateTransform Angle="0"/>
        </Image.RenderTransform>
      </Image>
      <ProgressBar IsIndeterminate="True"
                   Width="200"
                   Foreground="{StaticResource AccentBrush}"/>
      <TextBlock Text="Loading catalog..."
                 Foreground="{StaticResource TextMutedBrush}"
                 FontSize="13"
                 HorizontalAlignment="Center"/>
    </StackPanel>

    <!-- Empty state -->
    <StackPanel Grid.Row="2"
                IsVisible="{Binding HasItems, Converter={StaticResource BoolInverse}}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
      <TextBlock Text="No items found"
                 FontSize="16"
                 Foreground="{StaticResource TextMutedBrush}"
                 HorizontalAlignment="Center"/>
      <TextBlock Text="Adjust your search or filters"
                 FontSize="13"
                 Foreground="{StaticResource TextDimBrush}"
                 HorizontalAlignment="Center"/>
    </StackPanel>

    <!-- Catalog Grid -->
    <ListBox Grid.Row="2"
             ItemsSource="{Binding Items}"
             SelectedItem="{Binding SelectedItem}"
             BorderThickness="0"
             Background="Transparent"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             IsVisible="{Binding HasItems}">
      <ListBox.ItemsPanel>
        <ItemsPanelTemplate>
          <WrapPanel Orientation="Horizontal"/>
        </ItemsPanelTemplate>
      </ListBox.ItemsPanel>
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="models:CatalogItem">
          <Border Classes="Card"
                  Padding="0"
                  Width="240"
                  MinHeight="220"
                  Margin="0,0,16,16"
                  Cursor="Hand">
            <Border.Styles>
              <Style Selector="Border:pointerover">
                <Setter Property="BorderBrush" Value="{StaticResource AccentDimBrush}"/>
              </Style>
            </Border.Styles>
            <Grid RowDefinitions="Auto,*">
              <Border CornerRadius="8,8,0,0"
                      Height="130"
                      Background="{StaticResource SurfaceAltBrush}"
                      HorizontalAlignment="Stretch">
                <Grid>
                  <Image Source="{Binding Thumbnail}"
                         Stretch="UniformToFill"
                         IsVisible="{Binding IsThumbnailLoading, Converter={StaticResource BoolInverse}}"/>
                  <Border Background="{StaticResource SurfaceAltBrush}"
                          IsVisible="{Binding IsThumbnailLoading}">
                    <controls:CdSpinner/>
                  </Border>
                </Grid>
              </Border>
              <StackPanel Grid.Row="1" Spacing="6" Margin="12">
                <TextBlock Text="{Binding Name}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"/>
                <TextBlock Text="{Binding Description}"
                           FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           TextWrapping="Wrap"
                           MaxHeight="36"/>
                <TextBlock Text="{Binding Category}"
                           FontSize="10"
                           Foreground="{StaticResource AccentBrush}"
                           TextWrapping="Wrap"/>
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

  </Grid>

</UserControl>
