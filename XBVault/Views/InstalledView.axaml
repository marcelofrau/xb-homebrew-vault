<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="XBVault.Views.InstalledView">

  <Grid RowDefinitions="Auto,Auto,*" Margin="32">

    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="0,24,0,16">
      <TextBlock Text="INSTALLED"
                 Classes="PageTitle"/>
      <TextBlock Text="Manage apps and emulators installed on your Xbox"
                 Classes="Muted"
                 FontSize="14"
                 Margin="0,4,0,0"/>
    </StackPanel>

    <!-- Toolbar -->
    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                Spacing="8"
                Margin="0,0,0,16">
      <Button Command="{Binding RefreshPackagesCommand}"
              Padding="12,8">
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
          <Image Source="avares://XBVault/Assets/Icons/refresh.ico"
                 Width="16" Height="16"
                 Stretch="Uniform"/>
          <TextBlock Grid.Column="1"
                     Text="Refresh"
                     FontSize="13"/>
        </Grid>
      </Button>

      <Button Command="{Binding UninstallSelectedCommand}"
              Classes="Danger"
              Padding="12,8"
              IsEnabled="{Binding IsPackageSelected}">
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
          <Image Source="avares://XBVault/Assets/Icons/trash.ico"
                 Width="16" Height="16"
                 Stretch="Uniform"/>
          <TextBlock Grid.Column="1"
                     Text="Uninstall"
                     FontSize="13"/>
        </Grid>
      </Button>
    </StackPanel>

    <!-- Loading -->
    <StackPanel Grid.Row="2"
                IsVisible="{Binding IsLoading}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
      <ProgressBar IsIndeterminate="True"
                   Width="200"
                   Foreground="{StaticResource AccentBrush}"/>
      <TextBlock Text="Loading packages..."
                 Foreground="{StaticResource TextMutedBrush}"
                 FontSize="13"
                 HorizontalAlignment="Center"/>
    </StackPanel>

    <!-- Status message -->
    <TextBlock Grid.Row="2"
               Text="{Binding StatusMessage}"
               IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmpty}}"
               Foreground="{StaticResource TextMutedBrush}"
               FontSize="13"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>

    <!-- Package list -->
    <ListBox Grid.Row="2"
             ItemsSource="{Binding Packages}"
             SelectedItem="{Binding SelectedPackage}"
             BorderThickness="0"
             Background="Transparent"
             IsVisible="{Binding HasPackages}">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Classes="Card"
                  Padding="16"
                  Margin="0,0,0,8"
                  Cursor="Hand">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
              <!-- Icon placeholder -->
              <Border Width="40" Height="40"
                      CornerRadius="4"
                      Background="{StaticResource SurfaceAltBrush}">
                <TextBlock Text="P"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
              </Border>

              <!-- Info -->
              <StackPanel Grid.Column="1"
                          VerticalAlignment="Center"
                          Spacing="2">
                <TextBlock Text="{Binding Name}"
                           FontSize="14"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding FullName}"
                           FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           TextTrimming="CharacterEllipsis"/>
                <StackPanel Orientation="Horizontal" Spacing="12">
                  <TextBlock Text="{Binding Version}"
                             FontSize="11"
                             Foreground="{StaticResource TextDimBrush}"/>
                  <TextBlock Text="{Binding InstalledSizeBytes, StringFormat={}{0:N0} bytes}"
                             FontSize="11"
                             Foreground="{StaticResource TextDimBrush}"/>
                </StackPanel>
              </StackPanel>

              <!-- Arrow -->
              <TextBlock Grid.Column="2"
                         Text="›"
                         FontSize="20"
                         Foreground="{StaticResource TextDimBrush}"
                         VerticalAlignment="Center"/>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

  </Grid>

</UserControl>
