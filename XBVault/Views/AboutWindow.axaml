<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="XBVault.Views.AboutWindow"
        Title="About XB Homebrew Vault"
        Width="500" Height="420"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        WindowDecorations="None">

  <Border BorderBrush="#9ACA3C" BorderThickness="2" Margin="1">
    <Grid RowDefinitions="*,Auto">
      <Grid.Background>
        <ImageBrush Source="avares://XBVault/Assets/Views/AboutWindow/about-bg.png"
                    Stretch="UniformToFill"/>
      </Grid.Background>
      <StackPanel VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Spacing="2">
        <Image Source="avares://XBVault/Assets/Views/AboutWindow/about-appicon-80.png"
               Width="80" Height="80"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               Margin="0,0,0,6"/>
        <TextBlock Text="XB HOMEBREW"
                   FontSize="14"
                   FontWeight="Bold"
                   Foreground="{StaticResource AccentBrush}"
                   HorizontalAlignment="Center"
                   LetterSpacing="2"/>
        <TextBlock Text="VAULT"
                   FontSize="30"
                   FontWeight="Bold"
                   Foreground="{StaticResource TextBrush}"
                   HorizontalAlignment="Center"
                   LetterSpacing="3"
                   Margin="0,-4,0,0"/>
      <TextBlock Text="Desktop manager for Xbox Dev Mode homebrew"
                 FontSize="12"
                 Foreground="#B0B0B0"
                 HorizontalAlignment="Center"/>
      <Separator Width="40" Height="2"
                 Background="{StaticResource AccentBrush}"
                 Margin="0,4"
                 HorizontalAlignment="Center"/>
      <StackPanel Spacing="2" Margin="0,4,0,0">
        <TextBlock x:Name="VersionText"
                   FontSize="15"
                   FontWeight="Bold"
                   Foreground="{StaticResource AccentBrush}"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="Marcelo Frau"
                   FontSize="11"
                   Foreground="#888"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="GPL-3.0-only"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource YellowBrush}"
                   HorizontalAlignment="Center"/>
      </StackPanel>

      <Separator Width="120" Height="1"
                 Background="#555"
                 Margin="0,8"
                 HorizontalAlignment="Center"/>

      <Button Cursor="Hand"
              Background="Transparent"
              BorderThickness="0"
              HorizontalAlignment="Center"
              ToolTip.Tip="Visit Emulation Revival website"
              Click="OnErLinkClick">
        <StackPanel Spacing="2">
          <Image Source="avares://XBVault/Assets/Views/AboutWindow/about-erlogo.png"
                 Width="140" Height="40"
                 Stretch="Uniform"
                 HorizontalAlignment="Center"/>
          <TextBlock Text="Catalog powered by Emulation Revival"
                     FontSize="11"
                     Foreground="#777"
                     HorizontalAlignment="Center"/>
        </StackPanel>
      </Button>
      <Button Cursor="Hand"
              Background="Transparent"
              BorderThickness="0"
              HorizontalAlignment="Center"
              ToolTip.Tip="Open project on GitHub"
              Click="OnProjectLinkClick">
        <TextBlock Text="github.com/marcelofrau/xb-homebrew-vault"
                   FontSize="11"
                   Foreground="#999"
                   HorizontalAlignment="Center"/>
      </Button>
    </StackPanel>

    <Button Grid.Row="1"
            HorizontalAlignment="Center"
            Width="120"
            Margin="0,0,0,20"
            Padding="0,8"
            Click="OnCloseClick">
      <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6" HorizontalAlignment="Center">
<Image Source="avares://XBVault/Assets/Views/AboutWindow/about-close-20.png"
 Width="20" Height="20"
                Stretch="Uniform"/>
        <TextBlock Grid.Column="1" Text="CLOSE"
                   FontSize="12"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"/>
      </Grid>
    </Button>
  </Grid>
  </Border>

</Window>
