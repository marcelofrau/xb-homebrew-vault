<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:XBVault.ViewModels"
             xmlns:converters="using:XBVault.Converters"
             xmlns:svc="using:XBVault.Services"
             x:Class="XBVault.Views.LogsView"
             x:DataType="vm:LogsViewModel">

  <UserControl.Resources>
    <converters:LogLevelToBrushConverter x:Key="LevelToBrush"/>
    <converters:LogLevelToIconConverter x:Key="LevelToIcon"/>
  </UserControl.Resources>

  <Grid RowDefinitions="Auto,Auto,*" Margin="32,22,32,32" RowSpacing="12">
    <StackPanel Grid.Row="0">
      <TextBlock Text="LOGS" Classes="PageTitle"/>
      <TextBlock Text="View application log output"
                 Classes="Muted" FontSize="14" Margin="0,4,0,0"/>
    </StackPanel>
    <Border Grid.Row="1" Padding="8,6" CornerRadius="6" Background="{StaticResource SurfaceAltBrush}">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
        <StackPanel Orientation="Horizontal" Spacing="4">
          <CheckBox IsChecked="{Binding AutoScroll}"
                    FontSize="13" Foreground="White"/>
          <TextBlock Text="Auto-scroll"
                     FontSize="13" Foreground="White"
                     VerticalAlignment="Center"/>
        </StackPanel>
        <TextBlock Grid.Column="1"/>
        <Button Grid.Column="2" x:Name="CopyButton"
                Classes="Accent"
                Click="OnCopyClick"
                Padding="8,4"
                ToolTip.Tip="Copy all log entries">
          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="5">
            <Image Source="avares://XBVault/Assets/Views/ErrorDialog/errordialog-copy-20.png"
                   Width="16" Height="16" Stretch="Uniform"/>
            <TextBlock Grid.Column="1" x:Name="CopyButtonText"
                       Text="Copy All" FontSize="12" VerticalAlignment="Center"/>
          </Grid>
        </Button>
        <Button Grid.Column="3" x:Name="ClearButton"
                Classes="Accent"
                Click="OnClearClick"
                Padding="8,4"
                ToolTip.Tip="Clear all log entries">
          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="5">
            <Image Source="avares://XBVault/Assets/Views/SettingsView/settings-clear-20.png"
                   Width="16" Height="16" Stretch="Uniform"/>
            <TextBlock Grid.Column="1" Text="Clear" FontSize="12" VerticalAlignment="Center"/>
          </Grid>
        </Button>
      </Grid>
    </Border>
    <Border Grid.Row="2" Background="{StaticResource SurfaceAltBrush}" CornerRadius="6" Padding="12">
      <ScrollViewer Name="LogScrollViewer">
        <ListBox Name="LogListBox"
                 ItemsSource="{Binding Logs}"
                 SelectionMode="Multiple"
                 BorderThickness="0"
                 Background="Transparent">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Padding" Value="0"/>
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="svc:LogEntry">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                <Image Source="{Binding Level, Converter={StaticResource LevelToIcon}}"
                       Width="16" Height="16"
                       Stretch="Uniform"
                       VerticalAlignment="Center"/>
                <SelectableTextBlock Grid.Column="1"
                                     Text="{Binding Message}"
                                     FontFamily="{StaticResource MonoFont}"
                                     FontSize="15"
                                     TextWrapping="NoWrap"
                                     VerticalAlignment="Center"
                                     Foreground="{Binding Level, Converter={StaticResource LevelToBrush}}"/>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </ScrollViewer>
    </Border>
  </Grid>

</UserControl>
