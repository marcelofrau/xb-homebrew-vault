<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="XBVault.Views.InputDialog"
        Title="Input"
        WindowStartupLocation="CenterOwner"
        Width="380"
        SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        WindowDecorations="None"
        Background="{StaticResource SurfaceBrush}">

  <Window.Styles>
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
    </Style>
  </Window.Styles>

  <Border BorderBrush="#447F3E" BorderThickness="2" Margin="1">
    <Grid RowDefinitions="Auto,*">

      <Grid Height="32"
            PointerPressed="OnTitleBarPointerPressed"
            Background="{StaticResource TitleGradient}">
        <Grid.ColumnDefinitions>*,Auto</Grid.ColumnDefinitions>
        <TextBlock x:Name="TitleText"
                   Foreground="#1A1A1A"
                   FontSize="14"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   Margin="12,0"/>
        <Button Grid.Column="1" Classes="WindowClose"
                Click="OnCloseClick" ToolTip.Tip="Close"/>
      </Grid>

      <Border Grid.Row="1" BorderThickness="0">
        <StackPanel Margin="20,16,20,20" Spacing="16">

          <Grid ColumnDefinitions="48,*" ColumnSpacing="14">
            <Image x:Name="DialogIcon"
                   Width="48" Height="48"
                   Stretch="Uniform"
                   VerticalAlignment="Center"
                   IsVisible="False"/>
            <TextBlock x:Name="MessageText"
                       Grid.Column="1"
                       FontSize="14"
                       Foreground="{StaticResource TextBrush}"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"/>
          </Grid>

          <TextBox x:Name="InputTextBox"
                   FontSize="14"
                   Padding="8,6"
                   PlaceholderText="Type here..."
                   KeyDown="OnInputKeyDown"/>

          <StackPanel Orientation="Horizontal"
                      Spacing="8"
                      HorizontalAlignment="Right">
            <Button Click="OnCancelClick"
                    Padding="12,8"
                    MinWidth="90">
              <TextBlock Text="Cancel"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"/>
            </Button>
            <Button Click="OnOkClick"
                    Padding="12,8"
                    MinWidth="90">
              <TextBlock Text="OK"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"/>
            </Button>
          </StackPanel>

        </StackPanel>
      </Border>

    </Grid>
  </Border>
</Window>
