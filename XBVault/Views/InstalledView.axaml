<UserControl xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:vm="using:XBVault.ViewModels"
              xmlns:models="using:XBVault.Models"
              x:Class="XBVault.Views.InstalledView"
              x:DataType="vm:InstalledViewModel">

  <Grid RowDefinitions="Auto,Auto,*" Margin="32">

    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="0,24,0,16">
      <TextBlock Text="INSTALLED"
                 Classes="PageTitle"/>
      <TextBlock Text="Manage apps and emulators installed on your Xbox"
                 Classes="Muted"
                 FontSize="14"
                 Margin="0,4,0,0"/>
    </StackPanel>

    <!-- Toolbar -->
    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                Spacing="8"
                Margin="0,0,0,16">
      <Button Command="{Binding RefreshPackagesCommand}"
              Padding="12,8">
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
<Image Source="avares://XBVault/Assets/Views/InstalledView/installed-refresh-20.png"
                  Width="20" Height="20"
                  Stretch="Uniform"/>
          <TextBlock Grid.Column="1"
                     Text="Refresh"
                     FontSize="13"
                     VerticalAlignment="Center"/>
        </Grid>
      </Button>

      <Button Command="{Binding UninstallSelectedCommand}"
              Classes="Danger"
              Padding="12,8"
              IsEnabled="{Binding IsPackageSelected}">
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
<Image Source="avares://XBVault/Assets/Views/InstalledView/installed-uninstall-20.png"
                  Width="20" Height="20"
                  Stretch="Uniform"/>
          <TextBlock Grid.Column="1"
                     Text="Uninstall"
                     FontSize="13"
                     VerticalAlignment="Center"/>
        </Grid>
      </Button>
    </StackPanel>

    <!-- Loading -->
    <StackPanel Grid.Row="2"
                IsVisible="{Binding IsLoading}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
      <Image x:Name="SpinnerImage"
             Source="avares://XBVault/Assets/Views/InstalledView/installed-spinner-48.png"
             Width="48" Height="48"
             Stretch="Uniform"
             HorizontalAlignment="Center"
             RenderTransformOrigin="50% 50%">
        <Image.RenderTransform>
          <RotateTransform Angle="0"/>
        </Image.RenderTransform>
      </Image>
      <ProgressBar IsIndeterminate="True"
                   Width="200"
                   Foreground="{StaticResource AccentBrush}"/>
      <TextBlock Text="Loading packages..."
                 Foreground="{StaticResource TextMutedBrush}"
                 FontSize="13"
                 HorizontalAlignment="Center"/>
    </StackPanel>

    <!-- Status message -->
    <StackPanel Grid.Row="2"
                IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmpty}}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
      <Image Source="avares://XBVault/Assets/Views/InstalledView/installed-disconnected-64.png"
             Width="64" Height="64"
             Stretch="Uniform"
             HorizontalAlignment="Center"
             Opacity="0.6"/>
      <TextBlock Text="{Binding StatusMessage}"
                 Foreground="{StaticResource TextMutedBrush}"
                 FontSize="13"
                 HorizontalAlignment="Center"/>
    </StackPanel>

    <!-- Refresh prompt -->
    <StackPanel Grid.Row="2"
                IsVisible="{Binding ShowRefreshPrompt}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
      <Image Source="avares://XBVault/Assets/Views/InstalledView/installed-empty-64.png"
             Width="64" Height="64"
             Stretch="Uniform"
             HorizontalAlignment="Center"
             Opacity="0.6"/>
      <TextBlock Text="No packages loaded"
                 FontSize="16"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource TextMutedBrush}"
                 HorizontalAlignment="Center"/>
      <TextBlock Text="Click the Refresh button above to load installed packages"
                 FontSize="13"
                 Foreground="{StaticResource TextDimBrush}"
                 HorizontalAlignment="Center"
                 TextWrapping="Wrap"
                 MaxWidth="320"
                 TextAlignment="Center"/>
    </StackPanel>

    <!-- Package grid -->
    <ListBox Grid.Row="2"
             ItemsSource="{Binding Packages}"
             SelectedItem="{Binding SelectedPackage}"
             BorderThickness="0"
             Background="Transparent"
             IsVisible="{Binding ShowGrid}"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
      <ListBox.ItemsPanel>
        <ItemsPanelTemplate>
          <UniformGrid Columns="4"/>
        </ItemsPanelTemplate>
      </ListBox.ItemsPanel>
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="models:InstalledPackage">
          <Border Classes="Card"
                  Padding="10"
                  Margin="4"
                  Cursor="Hand">
            <Grid>
              <!-- Card content -->
              <StackPanel Spacing="6" HorizontalAlignment="Center"
                          Opacity="{Binding IsUninstalling, Converter={StaticResource BoolToOpacity}}">
                <Image Source="avares://XBVault/Assets/Views/InstalledView/installed-package-32.png"
                       Width="32" Height="32"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Name}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
                <TextBlock Text="{Binding Version}"
                           FontSize="12"
                           Foreground="{StaticResource AccentBrush}"
                           TextAlignment="Center"/>
                <TextBlock Text="{Binding DisplayPublisher}"
                           FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}"
                           TextTrimming="CharacterEllipsis"
                           IsVisible="{Binding DisplayPublisher, Converter={StaticResource StringNotEmpty}}"
                           TextAlignment="Center"/>
              </StackPanel>

              <!-- Uninstall overlay -->
              <Border Background="#AA222222"
                      CornerRadius="6"
                      IsVisible="{Binding IsUninstalling}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                  <TextBlock Text="Uninstalling..."
                             FontSize="13"
                             FontWeight="SemiBold"
                             Foreground="White"
                             TextAlignment="Center"/>
                </StackPanel>
              </Border>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

  </Grid>

</UserControl>
