<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:XBVault.ViewModels"
        xmlns:v="using:XBVault.Views"
         x:Class="XBVault.MainWindow"
         x:DataType="vm:MainViewModel"
         x:Name="Root"
        Title="XB Homebrew Vault"
        Width="1140" Height="800"
        WindowStartupLocation="CenterScreen"
        Icon="avares://XBVault/Assets/Views/MainWindow/mainwindow-app.png"
        Background="{StaticResource BgBrush}"
        WindowDecorations="None">

  <Window.Styles>
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
    </Style>

    <Style Selector="Button.SidebarBtn">
      <Style.Resources>
        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#332F333A"/>
        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#552F333A"/>
      </Style.Resources>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="Padding" Value="0,10"/>
      <Setter Property="Foreground" Value="#CCC"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style Selector="Button#ConnectPulseBtn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="Padding" Value="0,10"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Cursor" Value="Arrow"/>
      <Setter Property="Foreground" Value="#CCC"/>
      <Style.Animations>
        <Animation Duration="0:0:1.5" IterationCount="INFINITE" FillMode="Both">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="1"/>
          </KeyFrame>
          <KeyFrame Cue="50%">
            <Setter Property="Opacity" Value="0.4"/>
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1"/>
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <Style Selector="ListBoxItem.nav-item:pointerover">
      <Setter Property="RenderTransform" Value="scale(1.03)"/>
    </Style>

    <Style Selector="ListBoxItem.nav-item:pressed">
      <Setter Property="RenderTransform" Value="scale(0.98)"/>
    </Style>

    <Style Selector="ListBoxItem.nav-item:selected">
      <Setter Property="RenderTransform" Value="scale(1)"/>
      <Style Selector="^ > Grid > Border">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Opacity" Value="1"/>
      </Style>
    </Style>

    <Style Selector="ListBoxItem.nav-item">
      <Setter Property="Transitions">
        <Setter.Value>
          <Transitions>
            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"/>
          </Transitions>
        </Setter.Value>
      </Setter>
    </Style>

    <Style Selector="Image.statusDot">
      <Style.Animations>
        <Animation Duration="0:0:2" IterationCount="INFINITE" FillMode="Both">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="1"/>
          </KeyFrame>
          <KeyFrame Cue="50%">
            <Setter Property="Opacity" Value="0.5"/>
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1"/>
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <Style Selector="StackPanel.brand-logo">
      <Style.Animations>
        <Animation Duration="0:0:2.5" IterationCount="Infinite" FillMode="Both">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0.85"/>
          </KeyFrame>
          <KeyFrame Cue="50%">
            <Setter Property="Opacity" Value="1"/>
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="0.85"/>
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <Style Selector="Button#DiscordBtn:pointerover">
      <Setter Property="Background" Value="#5B63E0"/>
    </Style>

    <Style Selector="Button#DiscordBtn:pressed">
      <Setter Property="Background" Value="#3D44B8"/>
    </Style>
  </Window.Styles>

  <Border BorderBrush="#447F3E" BorderThickness="2" Margin="1">
    <Grid RowDefinitions="32,*" ColumnDefinitions="220,*">

    <!-- Title Bar -->
      <Grid Grid.ColumnSpan="2" Height="32"
            PointerPressed="OnTitleBarPointerPressed"
            Background="{StaticResource TitleGradient}">
      <Grid.ColumnDefinitions>*,Auto,Auto</Grid.ColumnDefinitions>
      <TextBlock Text="XB Homebrew Vault"
                 Foreground="#1A1A1A"
                 FontSize="14"
                 FontWeight="Bold"
                 VerticalAlignment="Center"
                 Margin="12,0"/>
      <Button Grid.Column="1" Width="32" Height="32"
              Padding="0"
              BorderThickness="0" Click="OnMinimizeClick"
              Cursor="Hand" Focusable="False"
              ToolTip.Tip="Minimize">
        <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-minimize-20.png"
               Width="20" Height="20"
               Stretch="Uniform"/>
        <Button.Styles>
          <Style Selector="Button">
            <Setter Property="Background" Value="Transparent"/>
          </Style>
          <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#33555555"/>
          </Style>
          <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#33555555"/>
          </Style>
        </Button.Styles>
      </Button>
      <Button Grid.Column="2" Classes="WindowClose"
              Click="OnCloseClick" ToolTip.Tip="Close"/>
    </Grid>

    <!-- Sidebar -->
    <Border Grid.Row="1" Grid.Column="0">
      <Border.Background>
        <ImageBrush Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-sidebarbg.png"
                    Stretch="UniformToFill"/>
      </Border.Background>
      <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- Brand -->
        <Border Padding="16,20,16,16"
                Grid.Row="0" Cursor="Hand"
                ToolTip.Tip="Visit marcelofrau.github.io/xb-homebrew-vault"
                PointerPressed="OnBrandClick">
          <StackPanel HorizontalAlignment="Center" Classes="brand-logo">
            <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-xbox-80.png"
                   Width="80" Height="80"
                   Stretch="Uniform"
                   Margin="0,0,0,8"
                   HorizontalAlignment="Center"/>
            <TextBlock Text="XB HOMEBREW"
                       Classes="BrandTitle"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       LetterSpacing="2"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="VAULT"
                       Classes="BrandTitle"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}"
                       LetterSpacing="3"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Nav Items (Blades) -->
        <ListBox Grid.Row="1"
                 BorderThickness="0"
                 Background="Transparent"
                 SelectedIndex="{Binding SelectedTab}"
                 SelectionMode="Single">
          <ListBoxItem Tag="Browse" Classes="nav-item" Padding="16,10">
             <Grid ColumnDefinitions="3,Auto,*" ColumnSpacing="10">
              <Border Background="Transparent" Opacity="0"
                      Width="3" CornerRadius="2" VerticalAlignment="Stretch"/>
              <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-browse-32.png"
                     Width="32" Height="32"
                     Grid.Column="1"
                     Stretch="Uniform"/>
              <TextBlock Text="BROWSE"
                         Grid.Column="2"
                         VerticalAlignment="Center"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TextMutedBrush}"
                         LetterSpacing="1"/>
            </Grid>
          </ListBoxItem>
          <ListBoxItem Tag="Installed" Classes="nav-item" Padding="16,10">
             <Grid ColumnDefinitions="3,Auto,*" ColumnSpacing="10">
              <Border Background="Transparent" Opacity="0"
                      Width="3" CornerRadius="2" VerticalAlignment="Stretch"/>
              <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-installed-32.png"
                     Width="32" Height="32"
                     Grid.Column="1"
                     Stretch="Uniform"/>
              <TextBlock Text="INSTALLED"
                         Grid.Column="2"
                         VerticalAlignment="Center"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TextMutedBrush}"
                         LetterSpacing="1"/>
            </Grid>
          </ListBoxItem>
          <ListBoxItem Tag="FileExplorer" Classes="nav-item" Padding="16,10">
             <Grid ColumnDefinitions="3,Auto,*" ColumnSpacing="10">
              <Border Background="Transparent" Opacity="0"
                      Width="3" CornerRadius="2" VerticalAlignment="Stretch"/>
              <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-fileexplorer-32.png"
                     Width="32" Height="32"
                     Grid.Column="1"
                     Stretch="Uniform"/>
              <TextBlock Text="FILE EXPLORER"
                         Grid.Column="2"
                         VerticalAlignment="Center"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TextMutedBrush}"
                         LetterSpacing="1"/>
            </Grid>
          </ListBoxItem>
          <ListBoxItem Tag="Tools" Classes="nav-item" Padding="16,10">
             <Grid ColumnDefinitions="3,Auto,*" ColumnSpacing="10">
              <Border Background="Transparent" Opacity="0"
                      Width="3" CornerRadius="2" VerticalAlignment="Stretch"/>
              <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-tools-32.png"
                     Width="32" Height="32"
                     Grid.Column="1"
                     Stretch="Uniform"/>
              <TextBlock Text="TOOLS"
                         Grid.Column="2"
                         VerticalAlignment="Center"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TextMutedBrush}"
                         LetterSpacing="1"/>
            </Grid>
          </ListBoxItem>
          <ListBoxItem Tag="Settings" Classes="nav-item" Padding="16,10">
             <Grid ColumnDefinitions="3,Auto,*" ColumnSpacing="10">
              <Border Background="Transparent" Opacity="0"
                      Width="3" CornerRadius="2" VerticalAlignment="Stretch"/>
              <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-settings-32.png"
                     Width="32" Height="32"
                     Grid.Column="1"
                     Stretch="Uniform"/>
              <TextBlock Text="SETTINGS"
                         Grid.Column="2"
                         VerticalAlignment="Center"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TextMutedBrush}"
                         LetterSpacing="1"/>
            </Grid>
          </ListBoxItem>
          <ListBoxItem Tag="Logs" Classes="nav-item" Padding="16,10">
             <Grid ColumnDefinitions="3,Auto,*" ColumnSpacing="10">
              <Border Background="Transparent" Opacity="0"
                      Width="3" CornerRadius="2" VerticalAlignment="Stretch"/>
              <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-logs-32.png"
                     Width="32" Height="32"
                     Grid.Column="1"
                     Stretch="Uniform"/>
              <TextBlock Text="LOGS"
                         Grid.Column="2"
                         VerticalAlignment="Center"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TextMutedBrush}"
                         LetterSpacing="1"/>
            </Grid>
          </ListBoxItem>
        </ListBox>

        <!-- ER Logo + Discord -->
        <StackPanel Grid.Row="2" Spacing="4" Margin="0,0,0,8">

          <!-- ER Logo -->
          <Button Cursor="Hand"
                  Background="Transparent"
                  BorderThickness="0"
                  HorizontalAlignment="Center"
                  ToolTip.Tip="Visit Emulation Revival website"
                  Click="OnErLinkClick">
            <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-erlogo.png"
                   Width="140"
                   Height="40"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"/>
          </Button>

          <!-- Discord -->
          <Button x:Name="DiscordBtn"
                  Click="OnDiscordClick"
                  HorizontalAlignment="Center"
                  Width="120"
                  Height="28"
                  Background="#4E56D0"
                  BorderThickness="0"
                  CornerRadius="6"
                  Cursor="Hand"
                  ToolTip.Tip="Join our Discord community">
            <StackPanel Orientation="Horizontal" Spacing="4"
                        HorizontalAlignment="Center">
              <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-discord-20.png"
                     Width="18" Height="18"
                     Stretch="Uniform"
                     VerticalAlignment="Center"/>
              <TextBlock Text="JOIN US"
                         FontSize="11"
                         FontWeight="Bold"
                         Foreground="White"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

        </StackPanel>

        <!-- Connection status + Connect + About -->
        <StackPanel Grid.Row="3" Spacing="4" Margin="16,0,16,16">

          <!-- Connect button (normal) -->
          <Button Classes="SidebarBtn"
                  HorizontalAlignment="Stretch"
                  FontWeight="SemiBold"
                  Command="{Binding ConnectCommand}"
                  IsVisible="{Binding CanConnect}">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
              <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-connect-32.png"
                     Width="32" Height="32"
                     Stretch="Uniform"
                     VerticalAlignment="Center"/>
              <TextBlock Grid.Column="1"
                          Text="CONNECT"
                          VerticalAlignment="Center"/>
            </Grid>
          </Button>

          <!-- Connect button (pulsing) -->
          <Button Classes="SidebarBtn"
                  x:Name="ConnectPulseBtn"
                  HorizontalAlignment="Stretch"
                  FontWeight="SemiBold"
                  IsVisible="{Binding ShowConnecting}">

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
              <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-connect-32.png"
                     Width="32" Height="32"
                     Stretch="Uniform"
                     VerticalAlignment="Center"/>
              <TextBlock Grid.Column="1"
                          Text="CONNECTING"
                          VerticalAlignment="Center"/>
            </Grid>
          </Button>

          <!-- Disconnect button -->
          <Button Classes="SidebarBtn"
                  HorizontalAlignment="Stretch"
                  FontWeight="SemiBold"
                  Click="OnDisconnectClick"
                  IsVisible="{Binding IsXboxConnected}">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
              <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-disconnect-32.png"
                     Width="32" Height="32"
                     Stretch="Uniform"
                     VerticalAlignment="Center"/>
              <TextBlock Grid.Column="1"
                          Text="DISCONNECT"
                          VerticalAlignment="Center"/>
            </Grid>
          </Button>

          <!-- About button -->
          <Button Classes="SidebarBtn"
                  HorizontalAlignment="Stretch"
                  FontWeight="SemiBold"
                  Command="{Binding OpenAboutCommand}">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
              <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-about-32.png"
                     Width="32" Height="32"
                     Stretch="Uniform"
                     VerticalAlignment="Center"/>
              <TextBlock Grid.Column="1"
                          Text="ABOUT"
                          VerticalAlignment="Center"/>
            </Grid>
          </Button>


        </StackPanel>

      </Grid>
    </Border>

    <!-- Content Area + Status Bar -->
    <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
            Grid.Column="1"
            Padding="0">
      <Grid RowDefinitions="*,28">
        <Carousel x:Name="ViewCarousel"
                  SelectedIndex="{Binding SelectedTab}">
          <Carousel.PageTransition>
            <CompositePageTransition>
              <CrossFade Duration="0:0:0.3"/>
              <PageSlide Duration="0:0:0.3" Orientation="Horizontal"/>
            </CompositePageTransition>
          </Carousel.PageTransition>
        </Carousel>

        <!-- Status Bar -->
        <Border Grid.Row="1" Background="#151515" Padding="12,0">
          <Grid ColumnDefinitions="Auto,Auto,*">
            <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-status-notconfigured-16.png"
                   Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"
                   IsVisible="{Binding IsNotConfigured}"/>
            <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-status-disconnected-16.png"
                   Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"
                   IsVisible="{Binding IsDisconnected}"/>
            <Image Source="avares://XBVault/Assets/Views/MainWindow/mainwindow-status-connected-16.png"
                   Classes="statusDot"
                   Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"
                   IsVisible="{Binding IsXboxConnected}"/>
            <TextBlock Grid.Column="1"
                        Text="{Binding ConnectionStatusText}"
                        Foreground="#AAA"
                        FontSize="11"
                        VerticalAlignment="Center"
                        Margin="6,0,0,0"/>
            <TextBlock Grid.Column="2"
                        x:Name="VersionText"
                        Foreground="#555"
                        FontSize="11"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"/>
          </Grid>
        </Border>
      </Grid>
    </Border>

    </Grid>
  </Border>

</Window>
