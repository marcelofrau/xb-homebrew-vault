<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:XBVault.ViewModels"
        xmlns:sys="using:System"
        x:Class="XBVault.Views.RefreshWindow"
        x:DataType="vm:RefreshViewModel"
        Title="Refresh Catalog"
        WindowStartupLocation="CenterOwner"
        Width="420"
        SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        WindowDecorations="None"
        Background="{StaticResource SurfaceBrush}">

  <Window.Styles>
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
    </Style>
  </Window.Styles>

  <Border BorderBrush="#447F3E" BorderThickness="2" Margin="1">
    <Grid RowDefinitions="Auto,*">
      <!-- Title Bar -->
      <Grid Height="32"
            PointerPressed="OnTitleBarPointerPressed"
            Background="{StaticResource TitleGradient}">
        <Grid.ColumnDefinitions>*,Auto</Grid.ColumnDefinitions>
        <TextBlock Text="Refresh Catalog"
                   Foreground="#1A1A1A"
                   FontSize="14"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   Margin="12,0"/>
        <Button Grid.Column="1" Classes="WindowClose"
                Click="OnCloseClick" ToolTip.Tip="Close"/>
      </Grid>

      <!-- Content -->
      <Border Grid.Row="1"
              BorderThickness="0">
        <StackPanel Margin="12" Spacing="8">

          <!-- Banner -->
          <Image Source="avares://XBVault/Assets/Views/RefreshWindow/refresh-fetch.png"
                 Stretch="None"
                 HorizontalAlignment="Center"/>

          <TextBlock Text="Forcing catalog re-download"
                     FontSize="14"
                     FontWeight="Bold"
                     Foreground="{StaticResource AccentBrush}"
                     HorizontalAlignment="Center"/>

          <!-- Details -->
          <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
            <TextBlock Text="Fetching latest from Emulation Revival"
                       FontSize="12"
                       Foreground="{StaticResource TextMutedBrush}"/>
            <TextBlock Grid.Row="1"
                       Text="Progress:"
                       FontSize="12"
                       Foreground="{StaticResource TextDimBrush}"/>
            <TextBlock Grid.Row="1" Grid.Column="1"
                       Text="{Binding Progress, StringFormat={}{0:P0}}"
                       FontSize="12"
                       HorizontalAlignment="Right"/>
          </Grid>

          <!-- Terminal output -->
          <Border Background="{StaticResource SurfaceAltBrush}"
                  CornerRadius="6"
                  Padding="8,6"
                  Height="180"
                  MaxHeight="180"
                  MinHeight="180">
            <ScrollViewer x:Name="OutputScroll">
              <ItemsControl ItemsSource="{Binding OutputLines}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="sys:String">
                    <TextBlock Text="{Binding}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="13"
                  Foreground="{StaticResource AccentGlowBrush}"
                                TextWrapping="Wrap"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>

          <!-- Progress bar -->
          <ProgressBar IsIndeterminate="True"
                       Height="4"
                       IsVisible="{Binding IsRunning}"
                       Foreground="{StaticResource AccentBrush}"/>

          <!-- Close button (always available) -->
          <Button Click="OnCloseClick"
                  Padding="10,6"
                  HorizontalAlignment="Right">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
              <Image Source="avares://XBVault/Assets/Views/RefreshWindow/refresh-closebtn-20.png"
                     Width="20" Height="20"
                     Stretch="Uniform"/>
              <TextBlock Grid.Column="1" Text="Close" VerticalAlignment="Center"/>
            </Grid>
          </Button>

        </StackPanel>
      </Border>
    </Grid>
  </Border>

</Window>
