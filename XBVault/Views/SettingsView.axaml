<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="XBVault.Views.SettingsView">

  <Grid RowDefinitions="Auto,*" Margin="32">

    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="0,24,0,16">
      <TextBlock Text="SETTINGS"
                 Classes="PageTitle"/>
      <TextBlock Text="Configure Xbox Dev Mode connection"
                 Classes="Muted"
                 FontSize="14"
                 Margin="0,4,0,0"/>
    </StackPanel>

    <ScrollViewer Grid.Row="1">
      <StackPanel Spacing="16" MaxWidth="500">

        <!-- Connection Section -->
        <Border Classes="Card" Padding="24">
          <StackPanel Spacing="12">

            <TextBlock Text="XBOX CONNECTION"
                       Classes="SectionHeader"/>

            <!-- Address -->
            <StackPanel Spacing="4">
              <TextBlock Text="Address"
                         FontSize="12"
                         Foreground="{StaticResource TextMutedBrush}"/>
              <TextBox Watermark="192.168.1.100"
                       Text="{Binding Address}"/>
            </StackPanel>

            <!-- Port -->
            <StackPanel Spacing="4">
              <TextBlock Text="Port"
                         FontSize="12"
                         Foreground="{StaticResource TextMutedBrush}"/>
              <TextBox Watermark="11443"
                       Text="{Binding Port}"/>
              <TextBlock Text="{Binding PortError}"
                         Foreground="{StaticResource DangerBrush}"
                         FontSize="11"
                         IsVisible="{Binding PortError, Converter={StaticResource StringNotEmpty}}"/>
            </StackPanel>

            <!-- HTTPS toggle -->
            <CheckBox IsChecked="{Binding UseHttps}"
                      Foreground="{StaticResource TextMutedBrush}"
                      FontSize="13">
              <TextBlock Text="Use HTTPS (recommended)"/>
            </CheckBox>

            <!-- Username -->
            <StackPanel Spacing="4">
              <TextBlock Text="Username"
                         FontSize="12"
                         Foreground="{StaticResource TextMutedBrush}"/>
              <TextBox Watermark="Dev Mode username"
                       Text="{Binding Username}"/>
            </StackPanel>

            <!-- Password -->
            <StackPanel Spacing="4">
              <TextBlock Text="Password"
                         FontSize="12"
                         Foreground="{StaticResource TextMutedBrush}"/>
              <TextBox Watermark="Dev Mode password"
                       Text="{Binding Password}"
                       PasswordChar="●"/>
            </StackPanel>

          </StackPanel>
        </Border>

        <!-- Actions -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">

          <Button Command="{Binding TestConnectionCommand}"
                  IsEnabled="{Binding IsTestingConnection, Converter={StaticResource BoolInverse}}"
                  Padding="16,8">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
              <Image Source="avares://XBVault/Assets/Views/SettingsView/settings-test-20.png"
                     Width="20" Height="20"
                     Stretch="Uniform"/>
              <TextBlock Grid.Column="1" Text="Test Connection"
                         VerticalAlignment="Center"/>
            </Grid>
          </Button>

          <Button Classes="Accent"
                  Command="{Binding SaveSettingsCommand}"
                  Padding="16,8">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
              <Image Source="avares://XBVault/Assets/Views/SettingsView/settings-save-20.png"
                     Width="20" Height="20"
                     Stretch="Uniform"/>
              <TextBlock Grid.Column="1" Text="Save"
                         VerticalAlignment="Center"/>
            </Grid>
          </Button>
        </StackPanel>

        <!-- Status -->
        <Border Classes="Card"
                Padding="16"
                IsVisible="{Binding ConnectionStatus, Converter={StaticResource StringNotEmpty}}">
          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
            <Ellipse Width="10"
                     Height="10"
                     Margin="0,6,0,6"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding ConnectionStatus}"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="13"
                       VerticalAlignment="Center"/>
          </Grid>
        </Border>

        <!-- Cache Section -->
        <Border Classes="Card" Padding="24">
          <StackPanel Spacing="12">
            <TextBlock Text="CACHE"
                       Classes="SectionHeader"/>
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Spacing="4">
                <TextBlock Text="Local package cache"
                           FontSize="13"/>
                <TextBlock Text="{Binding CacheSizeText}"
                           FontSize="12"
                           Foreground="{StaticResource TextMutedBrush}"/>
              </StackPanel>
              <Button Grid.Column="1"
                      Command="{Binding ClearCacheCommand}"
                      Padding="12,6"
                      VerticalAlignment="Center">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
<Image Source="avares://XBVault/Assets/Views/SettingsView/settings-clear-20.png"
                          Width="20" Height="20"
                          Stretch="Uniform"/>
                  <TextBlock Grid.Column="1" Text="Clear cache"
                             FontSize="12"
                             VerticalAlignment="Center"/>
                </Grid>
              </Button>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Logging Section -->
        <Border Classes="Card" Padding="24">
          <StackPanel Spacing="12">
            <TextBlock Text="LOGGING"
                       Classes="SectionHeader"/>
            <StackPanel Spacing="4">
              <TextBlock Text="Minimum log level"
                         FontSize="12"
                         Foreground="{StaticResource TextMutedBrush}"/>
              <ComboBox ItemsSource="{Binding LogLevels}"
                        SelectedItem="{Binding SelectedLogLevel}"
                        Width="200"/>
            </StackPanel>
            <TextBlock Text="Changes take effect immediately. Restart to capture startup logs."
                       FontSize="11"
                       Foreground="{StaticResource TextDimBrush}"
                       TextWrapping="Wrap"/>
          </StackPanel>
        </Border>

        <!-- Version -->
        <TextBlock x:Name="VersionText"
                   FontSize="11"
                   Foreground="{StaticResource TextDimBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,24"/>

      </StackPanel>
    </ScrollViewer>

  </Grid>

</UserControl>
