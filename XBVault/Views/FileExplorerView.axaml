<UserControl xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:models="using:XBVault.Models"
              xmlns:controls="using:XBVault.Controls"
               x:Class="XBVault.Views.FileExplorerView">

  <UserControl.Styles>
    <Style Selector="TreeViewItem">
      <Setter Property="IsExpanded" Value="{ReflectionBinding IsExpanded}"/>
      <Setter Property="(controls:TreeViewItemProperties.IsLastChild)" Value="{ReflectionBinding IsLastChild}" />
    </Style>
    <Style Selector="TreeViewItem:empty">
      <Setter Property="Padding" Value="3,0,0,0"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,Auto,*" Margin="32,32,32,16">

    <!-- Row 0: Header -->
    <Grid Grid.Row="0" Margin="0,14,0,16" ColumnDefinitions="*,Auto">
      <StackPanel>
        <TextBlock Text="FILE EXPLORER"
                   Classes="PageTitle"/>
        <TextBlock Text="Browse and manage files on your Xbox"
                   Classes="Muted"
                   FontSize="14"
                   Margin="0,4,0,0"/>
      </StackPanel>
      <TextBlock Grid.Column="1"
                 FontSize="11"
                 Foreground="{StaticResource TextMutedBrush}"
                 VerticalAlignment="Top"/>
    </Grid>

    <!-- Row 1: Toolbar -->
    <Grid Grid.Row="1"
          ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto"
          Margin="0,0,0,16">

      <Button Grid.Column="0"
              Command="{ReflectionBinding InitializeCommand}"
              IsEnabled="{ReflectionBinding CanBrowse}"
              Padding="10,6">
        <StackPanel Orientation="Horizontal" Spacing="5">
          <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-folder-20.png"
                 Width="20" Height="20"
                 Stretch="Uniform"/>
          <TextBlock Text="Browse"
                     FontSize="13"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </Button>

      <Button Grid.Column="1"
              Command="{ReflectionBinding RefreshCommand}"
              IsEnabled="{ReflectionBinding CanRefresh}"
              Padding="10,6"
              Margin="6,0,0,0">
        <StackPanel Orientation="Horizontal" Spacing="5">
          <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-refresh-20.png"
                 Width="20" Height="20"
                 Stretch="Uniform"/>
          <TextBlock Text="Refresh"
                     FontSize="13"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </Button>

      <!-- SFTP info -->
      <Button Grid.Column="2"
              Command="{ReflectionBinding OpenConnectionInfoCommand}"
              IsEnabled="{ReflectionBinding IsConnected}"
              Padding="10,6"
              Margin="6,0,0,0">
        <StackPanel Orientation="Horizontal" Spacing="5">
          <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-network-20.png"
                 Width="20" Height="20"
                 Stretch="Uniform"/>
          <TextBlock Text="SFTP Info"
                     FontSize="13"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </Button>

      <!-- Open in WinSCP -->
      <Button Grid.Column="3"
              Command="{ReflectionBinding OpenWinScpCommand}"
              Padding="10,6"
              Margin="6,0,0,0"
              IsVisible="{ReflectionBinding IsWindows}"
              IsEnabled="{ReflectionBinding IsConnected}">
        <StackPanel Orientation="Horizontal" Spacing="5">
          <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-winscp-24.png"
                 Width="20" Height="20"
                 Stretch="Uniform"/>
          <TextBlock Text="WinSCP"
                     FontSize="13"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </Button>

      <!-- Status block: error/warning/success/info -->
      <Border Grid.Column="4"
              IsVisible="{ReflectionBinding HasStatus}"
              CornerRadius="6"
              Padding="8,4"
              BorderThickness="1"
              BorderBrush="{ReflectionBinding StatusBorderBrush}"
              Background="{ReflectionBinding StatusBackground}"
              VerticalAlignment="Center"
              HorizontalAlignment="Right">
        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
          <Image Width="16" Height="16" Stretch="Uniform"
                 Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-status-error-20.png"
                 IsVisible="{ReflectionBinding IsStatusError}"/>
          <Image Width="16" Height="16" Stretch="Uniform"
                 Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-status-warning-20.png"
                 IsVisible="{ReflectionBinding IsStatusWarning}"/>
          <Image Width="16" Height="16" Stretch="Uniform"
                 Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-status-success-20.png"
                 IsVisible="{ReflectionBinding IsStatusSuccess}"/>
          <Image Width="16" Height="16" Stretch="Uniform"
                 Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-status-info-20.png"
                 IsVisible="{ReflectionBinding IsStatusInfo}"/>
          <TextBlock Text="{ReflectionBinding StatusMessage}"
                     Foreground="{ReflectionBinding StatusForeground}"
                     FontSize="14"
                     VerticalAlignment="Center"
                     TextWrapping="NoWrap"
                     TextTrimming="CharacterEllipsis"/>
        </StackPanel>
      </Border>

    </Grid>

    <!-- Row 2: Content area -->
    <!-- Disconnected -->
    <StackPanel Grid.Row="2"
                IsVisible="{ReflectionBinding ShowDisconnectedContent}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
      <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-disconnected-64.png"
             Width="64" Height="64"
             Stretch="Uniform"
             HorizontalAlignment="Center"
             Opacity="0.6"/>
      <TextBlock Text="Not connected"
                 FontSize="16"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource TextMutedBrush}"
                 HorizontalAlignment="Center"/>
      <TextBlock Text="Connect to browse Xbox files"
                 FontSize="13"
                 Foreground="{StaticResource TextDimBrush}"
                 HorizontalAlignment="Center"/>
      <Button Command="{ReflectionBinding ConnectCommand}"
              Padding="16,8"
              FontSize="14"
              HorizontalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <Image Source="avares://XBVault/Assets/Views/ConnectionWindow/connection-connect-20.png"
                 Width="20" Height="20" Stretch="Uniform"/>
          <TextBlock Text="Connect" VerticalAlignment="Center"/>
        </StackPanel>
      </Button>
    </StackPanel>

    <!-- Prompt -->
    <StackPanel Grid.Row="2"
                IsVisible="{ReflectionBinding ShowPromptContent}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
      <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-empty-64.png"
             Width="64" Height="64"
             Stretch="Uniform"
             HorizontalAlignment="Center"
             Opacity="0.6"/>
      <TextBlock Text="Ready to browse"
                 FontSize="16"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource TextMutedBrush}"
                 HorizontalAlignment="Center"/>
      <TextBlock Text="Click Browse to explore Xbox file system"
                 FontSize="13"
                 Foreground="{StaticResource TextDimBrush}"
                 HorizontalAlignment="Center"/>
      <Button Command="{ReflectionBinding InitializeCommand}"
              Padding="16,8"
              FontSize="14"
              HorizontalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-folder-20.png"
                 Width="20" Height="20"
                 Stretch="Uniform"/>
          <TextBlock Text="Browse Files" VerticalAlignment="Center"/>
        </StackPanel>
      </Button>
    </StackPanel>

    <!-- Loading -->
    <StackPanel Grid.Row="2"
                IsVisible="{ReflectionBinding IsLoading}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
      <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-folder-64.png"
             Width="64" Height="64"
             Stretch="Uniform"
             HorizontalAlignment="Center"
             Opacity="0.4"/>
      <TextBlock Text="{ReflectionBinding InitStepText}"
                 Foreground="{StaticResource TextMutedBrush}"
                 FontSize="13"
                 HorizontalAlignment="Center"/>
    </StackPanel>

    <!-- Main content: connected + initialized -->
    <Grid Grid.Row="2"
          IsVisible="{ReflectionBinding ShowReadyContent}"
          RowDefinitions="Auto,*,Auto"
          ColumnDefinitions="*,Auto">

      <!-- Row 0: Location bar -->
      <Grid Grid.ColumnSpan="2"
            ColumnDefinitions="*,Auto" ColumnSpacing="4"
            Margin="0,0,4,0">
        <TextBox Text="{ReflectionBinding CurrentPath}"
                 FontSize="13"
                 Padding="8,6"
                 VerticalContentAlignment="Center"/>
        <Button Grid.Column="1"
                Command="{ReflectionBinding NavigateToPathCommand}"
                CommandParameter="{ReflectionBinding CurrentPath}"
                Width="32" Height="32"
                Padding="0"
                ToolTip.Tip="Navigate">
          <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-go-16.png"
                 Width="16" Height="16"
                 Stretch="Uniform"/>
        </Button>
      </Grid>

      <!-- Row 1, Col 0: TreeView -->
      <Border Grid.Row="1"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="4"
              Margin="0,4,4,4">
        <TreeView x:Name="FolderTree"
                  ItemsSource="{ReflectionBinding TreeRoots}"
                  BorderThickness="0"
                  Background="Transparent"
                  HorizontalAlignment="Stretch"
                  Foreground="White">
          <TreeView.DataTemplates>
            <TreeDataTemplate DataType="models:SftpEntry"
                              ItemsSource="{ReflectionBinding Children}">
              <StackPanel Orientation="Horizontal" Spacing="6"
                          ToolTip.Tip="{ReflectionBinding ToolTip}">
                <Image Width="24" Height="24" Stretch="Uniform"
                       Source="{ReflectionBinding TreeIconPath}"
                       IsVisible="{ReflectionBinding ShowIcon}"/>
                <TextBlock Text="{ReflectionBinding Name}"
                           FontSize="14"
                           VerticalAlignment="Center"
                           IsVisible="{ReflectionBinding IsNotEditing}"/>
                <TextBox Text="{ReflectionBinding Name}"
                         FontSize="14"
                         VerticalAlignment="Center"
                         MinWidth="120"
                         IsVisible="{ReflectionBinding IsEditing}"/>
              </StackPanel>
            </TreeDataTemplate>
          </TreeView.DataTemplates>
        </TreeView>
      </Border>

      <!-- Row 2: Drop zone / Progress card -->
      <Border Grid.Row="2" Grid.ColumnSpan="2"
              Padding="10"
              CornerRadius="8"
              BorderThickness="2"
              Background="#0dffffff"
              BorderBrush="#33ffffff"
              Margin="0,4,0,0"
              x:Name="DropZoneBorder">
        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,Auto,*">
          <!-- Progress bar -->
          <ProgressBar Grid.Row="0" Grid.ColumnSpan="3"
                       IsVisible="{ReflectionBinding ShowActivity}"
                       Value="{ReflectionBinding ActivityProgress}"
                       Minimum="0" Maximum="1"
                       Height="4"
                       Foreground="{StaticResource AccentBrush}"
                       Margin="0,0,0,6"/>
          <!-- CD spinner (visible during activity) -->
          <Image Grid.Row="1" Grid.Column="0"
                 x:Name="CdSpinnerImage"
                 Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-cd-48.png"
                 Width="48" Height="48"
                 Stretch="Uniform"
                 VerticalAlignment="Center"
                 Margin="4,0,12,0"
                 IsVisible="{ReflectionBinding ShowActivity}"
                 RenderTransformOrigin="50% 50%">
            <Image.RenderTransform>
              <RotateTransform Angle="0"/>
            </Image.RenderTransform>
          </Image>
          <!-- Upload icon (idle) -->
          <Image Grid.Row="1" Grid.Column="0"
                 Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-upload-48.png"
                 Width="48" Height="48"
                 Stretch="Uniform"
                 VerticalAlignment="Center"
                 Margin="4,0,12,0"
                 Opacity="0.25"
                 IsVisible="{ReflectionBinding ShowIdle}"/>
          <!-- Activity status -->
          <StackPanel Grid.Row="1" Grid.Column="1"
                      IsVisible="{ReflectionBinding ShowActivity}"
                      Spacing="4"
                      VerticalAlignment="Center">
            <TextBlock Text="{ReflectionBinding ActivityText}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextMutedBrush}"/>
            <TextBlock Text="{ReflectionBinding ActivityProgress, StringFormat={}{0:P0}}"
                       FontSize="12"
                       Foreground="{StaticResource TextDimBrush}"/>
          </StackPanel>
          <!-- Drop prompt (idle) -->
          <StackPanel Grid.Row="1" Grid.Column="1"
                      IsVisible="{ReflectionBinding ShowIdle}"
                      Spacing="2"
                      VerticalAlignment="Center">
            <TextBlock Text="Drop files here to upload"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextMutedBrush}"/>
            <TextBlock Text="{ReflectionBinding CurrentPath, StringFormat='Destination: {0}'}"
                       FontSize="12"
                       Foreground="{StaticResource TextDimBrush}"/>
            <TextBlock Text="Drag &amp; drop multiple files from your PC"
                       FontSize="11"
                       Foreground="{StaticResource TextDimBrush}"/>
            <Button Padding="8,4"
                    FontSize="12"
                    HorizontalAlignment="Left"
                    Margin="0,4,0,0"
                    x:Name="BrowseFilesBtn">
              <StackPanel Orientation="Horizontal" Spacing="5">
          <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-add-file-20.png"
                        Width="16" Height="16"
                        Stretch="Uniform"
                        Opacity="0.7"/>
                <TextBlock Text="Browse Files" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Row 1, Col 1: Action buttons -->
      <StackPanel Grid.Row="1" Grid.Column="1"
                  Spacing="6"
                  Margin="0,4,0,0"
                  VerticalAlignment="Bottom">
        <Button Command="{ReflectionBinding CreateFolderCommand}"
                IsEnabled="{ReflectionBinding HasSelectedEntry}"
                Padding="8,6"
                Width="140"
                HorizontalContentAlignment="Stretch">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-newfolder-32.png"
                   Width="32" Height="32"
                   Stretch="Uniform"/>
            <TextBlock Text="New Folder"
                       FontSize="14"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Command="{ReflectionBinding DownloadFileCommand}"
                CommandParameter="{ReflectionBinding SelectedEntry}"
                IsEnabled="{ReflectionBinding HasSelectedEntry}"
                Padding="8,6"
                Width="140"
                HorizontalContentAlignment="Stretch">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-download-32.png"
                   Width="32" Height="32"
                   Stretch="Uniform"/>
            <TextBlock Text="Download"
                       FontSize="14"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Command="{ReflectionBinding DeleteEntryCommand}"
                CommandParameter="{ReflectionBinding SelectedEntry}"
                IsEnabled="{ReflectionBinding HasSelectedEntry}"
                Padding="8,6"
                Width="140"
                HorizontalContentAlignment="Stretch">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-delete-32.png"
                   Width="32" Height="32"
                   Stretch="Uniform"/>
            <TextBlock Text="Delete"
                       FontSize="14"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Command="{ReflectionBinding RenameEntryCommand}"
                CommandParameter="{ReflectionBinding SelectedEntry}"
                IsEnabled="{ReflectionBinding HasSelectedEntry}"
                Padding="8,6"
                Width="140"
                HorizontalContentAlignment="Stretch">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-rename-32.png"
                   Width="32" Height="32"
                   Stretch="Uniform"/>
            <TextBlock Text="Rename"
                       FontSize="14"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
      </StackPanel>
    </Grid>

  </Grid>

</UserControl>
