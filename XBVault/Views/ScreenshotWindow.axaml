<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:XBVault.ViewModels"
        x:Class="XBVault.Views.ScreenshotWindow"
        x:DataType="vm:ScreenshotViewModel"
        Title="Screenshot"
        WindowStartupLocation="CenterOwner"
        Width="900" Height="680"
        CanResize="False"
        ShowInTaskbar="False"
        WindowDecorations="None"
        Background="{StaticResource SurfaceBrush}">
  <Window.Styles>
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
    </Style>
  </Window.Styles>
  <Border BorderBrush="#447F3E" BorderThickness="2" Margin="1">
    <Grid RowDefinitions="Auto,*,Auto,Auto">
      <Grid Height="32" PointerPressed="OnTitleBarPointerPressed">
        <Grid.Background>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
            <GradientStop Color="#447F3E" Offset="0"/>
            <GradientStop Color="#9ACA3C" Offset="1"/>
          </LinearGradientBrush>
        </Grid.Background>
        <Grid.ColumnDefinitions>*,Auto</Grid.ColumnDefinitions>
        <TextBlock Text="Screenshot"
                   Foreground="#1A1A1A" FontSize="14" FontWeight="Bold"
                   VerticalAlignment="Center" Margin="12,0"/>
        <Button Grid.Column="1" Width="32" Height="32" Padding="0"
                BorderThickness="0" Click="OnCloseClick" Cursor="Hand"
                ToolTip.Tip="Close">
          <Image Source="avares://XBVault/Assets/Views/ConnectionWindow/connection-close-20.png"
                 Width="20" Height="20" Stretch="Uniform"/>
          <Button.Styles>
            <Style Selector="Button"><Setter Property="Background" Value="Transparent"/></Style>
            <Style Selector="Button:pointerover"><Setter Property="Background" Value="#CC3333"/></Style>
            <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter"><Setter Property="Background" Value="#CC3333"/></Style>
          </Button.Styles>
        </Button>
      </Grid>
      <Border Grid.Row="1" Padding="24,16">
        <Grid RowDefinitions="*,Auto,Auto" RowSpacing="8">

          <!-- Placeholder: shown when no screenshot -->
          <Border Grid.Row="0"
                  IsVisible="{Binding HasScreenshot, Converter={StaticResource BoolInverse}}"
                  CornerRadius="8"
                  BorderThickness="2"
                  BorderBrush="{StaticResource TextDimBrush}"
                  Background="{StaticResource SurfaceAltBrush}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8"
                        Opacity="0.4">
              <TextBlock Text="📷" FontSize="48" HorizontalAlignment="Center"/>
              <TextBlock Text="Screenshot preview"
                         FontSize="16" FontWeight="SemiBold"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="Click Capture to take a screenshot"
                         FontSize="13" HorizontalAlignment="Center"/>
            </StackPanel>
          </Border>

          <!-- Image area: shown when screenshot captured -->
          <Border Grid.Row="0"
                  IsVisible="{Binding HasScreenshot}"
                  CornerRadius="8"
                  BorderThickness="1"
                  BorderBrush="{StaticResource BorderBrush}">
            <Image Source="{Binding ScreenshotImage}"
                   MaxWidth="820" MaxHeight="540"
                   Stretch="Uniform" Margin="4"/>
          </Border>

          <!-- Buttons + Live capture row -->
          <Grid Grid.Row="1"
                ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto"
                ColumnSpacing="6">
            <Button Grid.Column="0"
                    Command="{Binding CaptureScreenshotCommand}"
                    Classes="Accent"
                    IsEnabled="{Binding IsLiveCapturing, Converter={StaticResource BoolInverse}}"
                    Padding="14,8" FontWeight="SemiBold">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                <Image Source="avares://XBVault/Assets/Views/ScreenshotWindow/screenshot-capture-20.png"
                       Width="20" Height="20" Stretch="Uniform"/>
                <TextBlock Grid.Column="1" Text="Capture" VerticalAlignment="Center"/>
              </Grid>
            </Button>
            <Button Grid.Column="1"
                    Command="{Binding SaveScreenshotCommand}"
                    IsVisible="{Binding HasScreenshot}"
                    IsEnabled="{Binding IsLiveCapturing, Converter={StaticResource BoolInverse}}"
                    Padding="12,7" FontWeight="SemiBold">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="5">
                <Image Source="avares://XBVault/Assets/Views/ScreenshotWindow/screenshot-save-20.png"
                       Width="18" Height="18" Stretch="Uniform"/>
                <TextBlock Grid.Column="1" Text="Save As..." VerticalAlignment="Center"/>
              </Grid>
            </Button>
            <TextBlock Grid.Column="2"
                       IsVisible="{Binding IsCapturing}"
                       Text="Capturing..."
                       FontSize="13" Foreground="{StaticResource TextMutedBrush}"
                       VerticalAlignment="Center"/>

            <!-- Live capture controls -->
            <ComboBox Grid.Column="3"
                      VerticalAlignment="Center"
                      ItemsSource="{Binding IntervalOptions}"
                      SelectedItem="{Binding SelectedInterval}"
                      IsEnabled="{Binding IsLiveCapturing, Converter={StaticResource BoolInverse}}"
                      Width="80"/>

            <TextBlock Grid.Column="4" Text="● LIVE"
                       Foreground="#E74C3C" FontSize="13" FontWeight="Bold"
                       VerticalAlignment="Center"
                       IsVisible="{Binding IsLiveCapturing}"/>

            <Button Grid.Column="5"
                    Command="{Binding ToggleLiveCaptureCommand}"
                    Padding="12,7" FontWeight="SemiBold">
              <ToolTip.Tip>
                <TextBlock Text="Periodically captures screenshots via the Xbox REST API. Not a real live stream — the interval controls how often a new screenshot is taken. Useful for monitoring what's happening on the console without leaving Windows."
                           TextWrapping="Wrap" MaxWidth="300"/>
              </ToolTip.Tip>
              <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="5">
                <Image Source="avares://XBVault/Assets/Views/ScreenshotWindow/screenshot-live-start-20.png"
                       Width="18" Height="18" Stretch="Uniform"
                       IsVisible="{Binding IsLiveCapturing, Converter={StaticResource BoolInverse}}"/>
                <Image Source="avares://XBVault/Assets/Views/ScreenshotWindow/screenshot-live-stop-20.png"
                       Width="18" Height="18" Stretch="Uniform"
                       IsVisible="{Binding IsLiveCapturing}"/>
                <TextBlock Grid.Column="1" VerticalAlignment="Center"
                           Text="{Binding LiveButtonText}"/>
              </Grid>
            </Button>
          </Grid>

          <!-- Status message -->
          <Border Grid.Row="2"
                  IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmpty}}"
                  Background="#1AE74C3C" BorderBrush="{StaticResource DangerBrush}"
                  BorderThickness="1" CornerRadius="6" Padding="14,10">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource DangerBrush}"
                       FontSize="13" FontWeight="SemiBold"/>
          </Border>

        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>
