<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="XBVault.SplashWindow"
        Title="XB Homebrew Vault"
        Width="500" Height="380"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        CanResize="False"
        Topmost="True">

  <Window.Background>
    <ImageBrush Source="avares://XBVault/Assets/Views/SplashWindow/splash-bg.png"
                Stretch="UniformToFill"/>
  </Window.Background>

  <Border BorderBrush="#9ACA3C" BorderThickness="2">
  <Grid RowDefinitions="*,Auto">
      <StackPanel VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Spacing="2">
        <Image Source="avares://XBVault/Assets/Views/SplashWindow/splash-appicon-80.png"
               Width="80" Height="80"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               Margin="0,0,0,6"/>
        <TextBlock Text="XB HOMEBREW"
                   FontSize="14"
                   FontWeight="Bold"
                   Foreground="{StaticResource AccentBrush}"
                   HorizontalAlignment="Center"
                   LetterSpacing="2"/>
        <TextBlock Text="VAULT"
                   FontSize="30"
                   FontWeight="Bold"
                   Foreground="{StaticResource TextBrush}"
                   HorizontalAlignment="Center"
                   LetterSpacing="3"
                   Margin="0,-4,0,0"/>
      <TextBlock Text="Desk top manager for Xbox Dev Mode homebrew"
                 FontSize="12"
                 Foreground="#B0B0B0"
                 HorizontalAlignment="Center"/>
      <Separator Width="40" Height="2"
                 Background="{StaticResource AccentBrush}"
                 Margin="0,4"
                 HorizontalAlignment="Center"/>
      <StackPanel Spacing="2" Margin="0,4,0,0">
        <TextBlock x:Name="VersionText"
                   FontSize="11"
                   Foreground="{StaticResource AccentBrush}"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="Marcelo Frau"
                   FontSize="11"
                   Foreground="#888"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="GPL-3.0-only"
                   FontSize="11"
                   Foreground="#888"
                   HorizontalAlignment="Center"/>
      </StackPanel>
    </StackPanel>

    <ProgressBar Grid.Row="1"
                 IsIndeterminate="True"
                 Height="2"
                 HorizontalAlignment="Stretch"
                 Foreground="{StaticResource AccentBrush}"
                 Background="Transparent"
                 Margin="32,0,32,24"/>
  </Grid>
  </Border>

</Window>
