<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:XBVault.ViewModels"
        x:Class="XBVault.Views.ConfirmWindow"
        x:DataType="vm:ConfirmViewModel"
        Title="{Binding Title}"
        WindowStartupLocation="CenterOwner"
        Width="380"
        SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        WindowDecorations="None"
        Background="{StaticResource SurfaceBrush}">

  <Window.Styles>
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
    </Style>
  </Window.Styles>

  <Border BorderBrush="#447F3E" BorderThickness="2" Margin="1">
    <Grid RowDefinitions="Auto,*">

      <Grid Height="32"
            PointerPressed="OnTitleBarPointerPressed">
        <Grid.Background>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
            <GradientStop Color="#447F3E" Offset="0"/>
            <GradientStop Color="#9ACA3C" Offset="1"/>
          </LinearGradientBrush>
        </Grid.Background>
        <Grid.ColumnDefinitions>*,Auto</Grid.ColumnDefinitions>
        <TextBlock Text="{Binding Title}"
                   Foreground="#1A1A1A"
                   FontSize="14"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   Margin="12,0"/>
        <Button Grid.Column="1"
                Width="32" Height="32"
                Padding="0"
                BorderThickness="0"
                Click="OnCloseClick"
                Cursor="Hand"
                ToolTip.Tip="Close">
          <Image Source="avares://XBVault/Assets/Views/ErrorDialog/errordialog-close-20.png"
                 Width="20" Height="20"
                 Stretch="Uniform"/>
          <Button.Styles>
            <Style Selector="Button">
              <Setter Property="Background" Value="Transparent"/>
            </Style>
            <Style Selector="Button:pointerover">
              <Setter Property="Background" Value="#CC3333"/>
            </Style>
            <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
              <Setter Property="Background" Value="#CC3333"/>
            </Style>
          </Button.Styles>
        </Button>
      </Grid>

      <Border Grid.Row="1" BorderThickness="0">
        <StackPanel Margin="20,16,20,20" Spacing="16">

          <Grid ColumnDefinitions="48,*" ColumnSpacing="14">
            <Image Source="{Binding MessageIcon}"
                   Width="48" Height="48"
                   Stretch="Uniform"
                   VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding Message}"
                       FontSize="14"
                       Foreground="{StaticResource TextBrush}"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"/>
          </Grid>

          <StackPanel Orientation="Horizontal"
                      Spacing="8"
                      HorizontalAlignment="Right">
            <Button Command="{Binding CancelCommand}"
                    Padding="12,8"
                    MinWidth="90"
                    IsVisible="{Binding CancelText, Converter={StaticResource StringNotEmpty}}">
              <TextBlock Text="{Binding CancelText}"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"/>
            </Button>
            <Button x:Name="ConfirmBtn"
                    Command="{Binding ConfirmCommand}"
                    Padding="12,8"
                    MinWidth="90">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Image Source="{Binding Icon}"
                       Width="20" Height="20"
                       Stretch="Uniform"
                       IsVisible="{Binding HasIcon}"/>
                <TextBlock Text="{Binding ConfirmText}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
              </StackPanel>
            </Button>
          </StackPanel>

        </StackPanel>
      </Border>

    </Grid>
  </Border>

</Window>
