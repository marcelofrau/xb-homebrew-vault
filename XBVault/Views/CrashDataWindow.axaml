<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:XBVault.ViewModels"
        xmlns:models="using:XBVault.Models"
        x:Class="XBVault.Views.CrashDataWindow"
        x:DataType="vm:CrashDataViewModel"
        Title="Crash Data"
        WindowStartupLocation="CenterOwner"
        Width="680" Height="480"
        CanResize="False"
        ShowInTaskbar="False"
        WindowDecorations="None"
        Background="{StaticResource SurfaceBrush}">
  <Window.Styles>
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
    </Style>
  </Window.Styles>
  <Border BorderBrush="#447F3E" BorderThickness="2" Margin="1">
    <Grid RowDefinitions="Auto,*">
      <Grid Height="32" PointerPressed="OnTitleBarPointerPressed"
            Background="{StaticResource TitleGradient}">
        <Grid.ColumnDefinitions>*,Auto</Grid.ColumnDefinitions>
        <TextBlock Text="Crash Data"
                   Foreground="#1A1A1A" FontSize="14" FontWeight="Bold"
                   VerticalAlignment="Center" Margin="12,0"/>
        <Button Grid.Column="1" Classes="WindowClose"
                Click="OnCloseClick" ToolTip.Tip="Close"/>
      </Grid>
      <Border Grid.Row="1" Padding="20">
        <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12">
          <TextBlock Grid.Row="0"
                     Text="Crash dumps and diagnostics from the Xbox console"
                     FontSize="11"
                     Foreground="{StaticResource TextMutedBrush}"/>

          <Border Grid.Row="1" Background="{StaticResource SurfaceAltBrush}"
                  CornerRadius="6" Padding="14,10">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
              <TextBlock VerticalAlignment="Center"
                         Text="Crash Dump Collection" FontSize="13"
                         Foreground="{StaticResource TextMutedBrush}"/>
              <TextBlock Grid.Column="1" VerticalAlignment="Center"
                         FontSize="13" FontWeight="SemiBold">
                <Run Text="{Binding CrashDumpEnabled, StringFormat='{}{0}'}"/>
              </TextBlock>
              <Button Grid.Column="2" Command="{Binding ToggleCrashDumpCommand}"
                      Padding="12,6">
                <TextBlock Text="{Binding CrashDumpEnabled, StringFormat='{}{0}'}"
                           VerticalAlignment="Center"/>
              </Button>
            </Grid>
          </Border>

          <Border Grid.Row="2"
                  Background="{StaticResource SurfaceAltBrush}"
                  CornerRadius="6" Padding="0">
            <Grid RowDefinitions="Auto,*">
              <Border Padding="0" CornerRadius="6,6,0,0"
                      Background="{StaticResource TitleGradient}">
                <Grid ColumnDefinitions="*,120,140" ColumnSpacing="10" Margin="8,6">
                  <TextBlock Text="File Name" FontSize="11" FontWeight="Bold" Foreground="#1A1A1A"/>
                  <TextBlock Grid.Column="1" Text="Size" FontSize="11" FontWeight="Bold"
                             Foreground="#1A1A1A" TextAlignment="Right"/>
                  <TextBlock Grid.Column="2" Text="Created" FontSize="11" FontWeight="Bold"
                             Foreground="#1A1A1A" TextAlignment="Right"/>
                </Grid>
              </Border>
              <ScrollViewer Grid.Row="1">
                <ListBox ItemsSource="{Binding CrashDumps}"
                         SelectedItem="{Binding SelectedCrashDump}"
                         BorderThickness="0" Background="Transparent">
                  <ListBox.Styles>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                      <Setter Property="Background" Value="#33447F3E"/>
                    </Style>
                  </ListBox.Styles>
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:CrashDumpInfo">
                      <Border Padding="8,6">
                        <Grid ColumnDefinitions="*,120,140" ColumnSpacing="10">
                          <TextBlock Text="{Binding FileName}"
                                     FontSize="12" FontWeight="SemiBold"/>
                          <TextBlock Grid.Column="1" Text="{Binding FileSizeDisplay}"
                                     FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                     TextAlignment="Right"/>
                          <TextBlock Grid.Column="2" Text="{Binding CreatedAtDisplay}"
                                     FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                     TextAlignment="Right"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </ScrollViewer>
            </Grid>
          </Border>

          <Grid Grid.Row="3" ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="8">
            <Button Grid.Column="0" Command="{Binding RefreshCommand}"
                    IsEnabled="{Binding IsRefreshing, Converter={StaticResource BoolInverse}}"
                    Padding="14,8">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                <Image Source="avares://XBVault/Assets/Views/ProcessesWindow/processes-refresh-20.png"
                       Width="20" Height="20" Stretch="Uniform"/>
                <TextBlock Grid.Column="1" Text="Refresh" VerticalAlignment="Center"/>
              </Grid>
            </Button>
            <Button Grid.Column="1" Command="{Binding DeleteSelectedCommand}"
                    IsEnabled="{Binding IsCrashDumpSelected}"
                    Classes="Danger" Padding="14,8">
              <TextBlock Text="Delete Selected" VerticalAlignment="Center"/>
            </Button>
            <Button Grid.Column="2" Command="{Binding DeleteAllCommand}"
                    IsEnabled="{Binding HasCrashDumps}"
                    Classes="Danger" Padding="14,8">
              <TextBlock Text="Delete All" VerticalAlignment="Center"/>
            </Button>
            <TextBlock Grid.Column="3"
                       IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmpty}}"
                       Text="{Binding StatusMessage}"
                       Foreground="{StaticResource DangerBrush}"
                       FontSize="12" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="8,0,0,0"/>
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>