<UserControl xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:models="using:XBVault.Models"
               xmlns:controls="using:XBVault.Controls"
               xmlns:vm="using:XBVault.ViewModels"
               Cursor="{Binding Cursor}" x:Class="XBVault.Views.FileExplorerView" x:DataType="vm:FileExplorerViewModel">

  <UserControl.Styles>
    <Style Selector="TreeViewItem">
      <Setter Property="IsExpanded" Value="{ReflectionBinding IsExpanded, Mode=TwoWay}"/>
      <Setter Property="(controls:TreeViewItemProperties.IsLastChild)" Value="{ReflectionBinding IsLastChild}" />
      <Setter Property="Padding" Value="1,0"/>
    </Style>

  </UserControl.Styles>

  <Grid RowDefinitions="Auto,Auto,*" Margin="16,32,16,16">

    <!-- Row 0: Header -->
    <Grid Grid.Row="0" Margin="0,14,0,16" ColumnDefinitions="*,Auto">
      <StackPanel>
        <TextBlock Text="FILE EXPLORER"
                   Classes="PageTitle"/>
        <TextBlock Text="Browse and manage files on your Xbox"
                   Classes="Muted"
                   FontSize="14"
                   Margin="0,4,0,0"/>
      </StackPanel>
      <TextBlock Grid.Column="1"
                 FontSize="11"
                 Foreground="{StaticResource TextMutedBrush}"
                 VerticalAlignment="Top"/>
    </Grid>

    <!-- Row 1: Toolbar -->
    <Grid Grid.Row="1"
          ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto"
          Margin="0,0,0,16">

      <Button x:Name="BrowseBtn"
              Grid.Column="0"
              Command="{ReflectionBinding InitializeCommand}"
              IsEnabled="{ReflectionBinding CanBrowse}"
              Padding="10,6">
        <StackPanel Orientation="Horizontal" Spacing="5">
          <Grid>
            <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-folder-20.png"
                   IsVisible="{Binding #BrowseBtn.IsEnabled}"
                   Width="20" Height="20" Stretch="Uniform"/>
            <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-folder-20-disabled.png"
                   IsVisible="{Binding #BrowseBtn.IsEnabled, Converter={StaticResource BoolInverse}}"
                   Width="20" Height="20" Stretch="Uniform"/>
          </Grid>
          <TextBlock Text="Browse"
                     FontSize="13"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </Button>

      <Button x:Name="RefreshBtn"
              Grid.Column="1"
              Command="{ReflectionBinding RefreshCommand}"
              IsEnabled="{ReflectionBinding CanRefresh}"
              Padding="10,6"
              Margin="6,0,0,0">
        <StackPanel Orientation="Horizontal" Spacing="5">
          <Grid>
            <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-refresh-20.png"
                   IsVisible="{Binding #RefreshBtn.IsEnabled}"
                   Width="20" Height="20" Stretch="Uniform"/>
            <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-refresh-20-disabled.png"
                   IsVisible="{Binding #RefreshBtn.IsEnabled, Converter={StaticResource BoolInverse}}"
                   Width="20" Height="20" Stretch="Uniform"/>
          </Grid>
          <TextBlock Text="Refresh"
                     FontSize="13"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </Button>

      <!-- SFTP info -->
      <Button x:Name="SftpInfoBtn"
              Grid.Column="2"
              Command="{ReflectionBinding OpenConnectionInfoCommand}"
              IsEnabled="{ReflectionBinding IsConnected}"
              Padding="10,6"
              Margin="6,0,0,0">
        <StackPanel Orientation="Horizontal" Spacing="5">
          <Grid>
            <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-network-20.png"
                   IsVisible="{Binding #SftpInfoBtn.IsEnabled}"
                   Width="20" Height="20" Stretch="Uniform"/>
            <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-network-20-disabled.png"
                   IsVisible="{Binding #SftpInfoBtn.IsEnabled, Converter={StaticResource BoolInverse}}"
                   Width="20" Height="20" Stretch="Uniform"/>
          </Grid>
          <TextBlock Text="SFTP Info"
                     FontSize="13"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </Button>

      <!-- Open in WinSCP -->
      <Button x:Name="WinScpBtn"
              Grid.Column="3"
              Command="{ReflectionBinding OpenWinScpCommand}"
              Padding="10,6"
              Margin="6,0,0,0"
              IsVisible="{ReflectionBinding IsWindows}"
              IsEnabled="{ReflectionBinding IsConnected}">
        <StackPanel Orientation="Horizontal" Spacing="5">
          <Grid>
            <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-winscp-24.png"
                   IsVisible="{Binding #WinScpBtn.IsEnabled}"
                   Width="20" Height="20" Stretch="Uniform"/>
            <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-winscp-24-disabled.png"
                   IsVisible="{Binding #WinScpBtn.IsEnabled, Converter={StaticResource BoolInverse}}"
                   Width="20" Height="20" Stretch="Uniform"/>
          </Grid>
          <TextBlock Text="WinSCP"
                     FontSize="13"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </Button>

      <!-- Toggle all drives -->
      <ToggleButton Grid.Column="4"
                    IsChecked="{ReflectionBinding ShowAllDrives}"
                    Padding="10,6"
                    Margin="6,0,0,0"
                    ToolTip.Tip="Show all system drives (default: D: and E: only)">
        <ToggleButton.Styles>
          <Style Selector="ToggleButton Image">
            <Setter Property="Source" Value="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-drives-off-20.png"/>
          </Style>
          <Style Selector="ToggleButton:checked Image">
            <Setter Property="Source" Value="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-drives-on-20.png"/>
          </Style>
        </ToggleButton.Styles>
        <StackPanel Orientation="Horizontal" Spacing="5">
          <Image Width="20" Height="20"
                 Stretch="Uniform"/>
          <TextBlock Text="All drives"
                     FontSize="12"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </ToggleButton>

      <!-- Status block: error/warning/success/info -->
      <Border Grid.Column="5"
              IsVisible="{ReflectionBinding HasStatus}"
              CornerRadius="6"
              Padding="8,4"
              BorderThickness="1"
              BorderBrush="{ReflectionBinding StatusBorderBrush}"
              Background="{ReflectionBinding StatusBackground}"
              VerticalAlignment="Center"
              HorizontalAlignment="Right">
        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
          <Image Width="16" Height="16" Stretch="Uniform"
                 Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-status-error-20.png"
                 IsVisible="{ReflectionBinding IsStatusError}"/>
          <Image Width="16" Height="16" Stretch="Uniform"
                 Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-status-warning-20.png"
                 IsVisible="{ReflectionBinding IsStatusWarning}"/>
          <Image Width="16" Height="16" Stretch="Uniform"
                 Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-status-success-20.png"
                 IsVisible="{ReflectionBinding IsStatusSuccess}"/>
          <Image Width="16" Height="16" Stretch="Uniform"
                 Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-status-info-20.png"
                 IsVisible="{ReflectionBinding IsStatusInfo}"/>
          <TextBlock Text="{ReflectionBinding StatusMessage}"
                     Foreground="{ReflectionBinding StatusForeground}"
                     FontSize="14"
                     VerticalAlignment="Center"
                     TextWrapping="NoWrap"
                     TextTrimming="CharacterEllipsis"
                     MaxWidth="350"
                     ToolTip.Tip="{ReflectionBinding StatusMessage}"/>
        </StackPanel>
      </Border>

    </Grid>

    <!-- Row 2: Content area -->
    <!-- Disconnected -->
    <StackPanel Grid.Row="2"
                IsVisible="{ReflectionBinding ShowDisconnectedContent}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
      <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-disconnected-64.png"
             Width="64" Height="64"
             Stretch="Uniform"
             HorizontalAlignment="Center"
             Opacity="0.6"/>
      <TextBlock Text="Not connected"
                 FontSize="16"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource TextMutedBrush}"
                 HorizontalAlignment="Center"/>
      <TextBlock Text="Connect to browse Xbox files"
                 FontSize="13"
                 Foreground="{StaticResource TextDimBrush}"
                 HorizontalAlignment="Center"/>
      <Button Command="{ReflectionBinding ConnectCommand}"
              Padding="16,8"
              FontSize="14"
              HorizontalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <Image Source="avares://XBVault/Assets/Views/ConnectionWindow/connection-connect-20.png"
                 Width="20" Height="20" Stretch="Uniform"/>
          <TextBlock Text="Connect" VerticalAlignment="Center"/>
        </StackPanel>
      </Button>
    </StackPanel>

    <!-- Prompt -->
    <StackPanel Grid.Row="2"
                IsVisible="{ReflectionBinding ShowPromptContent}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
      <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-empty-64.png"
             Width="64" Height="64"
             Stretch="Uniform"
             HorizontalAlignment="Center"
             Opacity="0.6"/>
      <TextBlock Text="Ready to browse"
                 FontSize="16"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource TextMutedBrush}"
                 HorizontalAlignment="Center"/>
      <TextBlock Text="Click Browse to explore Xbox file system"
                 FontSize="13"
                 Foreground="{StaticResource TextDimBrush}"
                 HorizontalAlignment="Center"/>
      <Button Command="{ReflectionBinding InitializeCommand}"
              Padding="16,8"
              FontSize="14"
              HorizontalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-folder-20.png"
                 Width="20" Height="20"
                 Stretch="Uniform"/>
          <TextBlock Text="Browse Files" VerticalAlignment="Center"/>
        </StackPanel>
      </Button>
    </StackPanel>

    <!-- Loading -->
    <StackPanel Grid.Row="2"
                IsVisible="{ReflectionBinding IsLoading}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">
      <Image x:Name="LoadingSpinnerImage"
             Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-cd-48.png"
             Width="48" Height="48"
             Stretch="Uniform"
             HorizontalAlignment="Center"
             RenderTransformOrigin="50% 50%">
        <Image.RenderTransform>
          <RotateTransform Angle="0"/>
        </Image.RenderTransform>
      </Image>
      <TextBlock Text="{ReflectionBinding InitStepText}"
                 Foreground="{StaticResource TextMutedBrush}"
                 FontSize="13"
                 HorizontalAlignment="Center"/>
    </StackPanel>

    <!-- Main content: connected + initialized -->
    <Grid Grid.Row="2"
          IsVisible="{ReflectionBinding ShowReadyContent}"
          RowDefinitions="Auto,*,Auto">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="2*" MinWidth="180"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="8*" MinWidth="220"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

      <!-- Row 0: Location bar (colspan 3; Go button sits in col 3 for alignment) -->
      <Grid Grid.ColumnSpan="3"
            Margin="0,0,4,0">
        <TextBox Text="{ReflectionBinding CurrentPath}"
                 FontSize="13"
                 Padding="8,6"
                 VerticalContentAlignment="Center"/>
      </Grid>
      <!-- Go button (col 3 = same column as action buttons) -->
      <Button Grid.Row="0" Grid.Column="3"
              Command="{ReflectionBinding NavigateToPathCommand}"
              CommandParameter="{ReflectionBinding CurrentPath}"
              Width="105"
              Padding="6,4"
              Margin="4,0,0,0"
              HorizontalContentAlignment="Stretch"
              ToolTip.Tip="Navigate to path">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-play-24.png"
                 Width="24" Height="24"
                 Stretch="Uniform"/>
          <TextBlock Text="Go"
                     FontSize="12"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </Button>

      <!-- Row 1, Col 0: TreeView (folders only) -->
      <Border Grid.Row="1"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="4"
              Margin="0,4,4,4">
        <TreeView x:Name="FolderTree"
                  ItemsSource="{ReflectionBinding TreeRoots}"
                  BorderThickness="0"
                  Background="Transparent"
                  HorizontalAlignment="Stretch"
                  Foreground="White"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
          <TreeView.DataTemplates>
            <TreeDataTemplate DataType="models:SftpEntry"
                               ItemsSource="{ReflectionBinding Children}">
              <StackPanel Orientation="Horizontal" Spacing="2"
                           Margin="{ReflectionBinding HeaderMargin}"
                           ToolTip.Tip="{ReflectionBinding Name}">
                <Image Width="20" Height="20" Stretch="Uniform"
                       Source="{ReflectionBinding TreeIconPath}"
                       IsVisible="{ReflectionBinding ShowIcon}"/>
                <TextBlock Text="{ReflectionBinding Name}"
                            FontSize="13"
                            VerticalAlignment="Center"
                            TextTrimming="CharacterEllipsis"/>
              </StackPanel>
            </TreeDataTemplate>
          </TreeView.DataTemplates>
        </TreeView>
      </Border>

      <!-- GridSplitter -->
      <GridSplitter Grid.Row="1" Grid.Column="1"
                    Width="3"
                    ResizeBehavior="PreviousAndNext"
                    Background="Transparent"
                    Margin="0,4,0,4"/>

      <!-- Row 1, Col 2: ListBox (file list) -->
      <Border Grid.Row="1" Grid.Column="2"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="4"
              Margin="0,4,4,4">
        <ListBox x:Name="FileListBox"
                 ItemsSource="{ReflectionBinding CurrentEntries}"
                 SelectionMode="Multiple"
                 BorderThickness="0"
                 Background="Transparent"
                 Foreground="White">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Padding" Value="2,0"/>
            </Style>
          </ListBox.Styles>
          <ListBox.DataTemplates>
            <DataTemplate DataType="models:SftpEntry">
              <Grid ColumnDefinitions="20,*,Auto" Margin="0,0,6,0"
                    ToolTip.Tip="{ReflectionBinding Name}">
                <Image Width="20" Height="20" Stretch="Uniform"
                       Source="{ReflectionBinding IconPath}"/>
                <TextBlock Grid.Column="1"
                            Text="{ReflectionBinding Name}"
                            FontSize="13"
                            VerticalAlignment="Center"
                            Margin="4,0,8,0"
                            TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="2"
                           Text="{ReflectionBinding FormattedSize}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextDimBrush}"
                           TextAlignment="Right"/>
              </Grid>
            </DataTemplate>
          </ListBox.DataTemplates>
        </ListBox>
      </Border>

      <!-- Row 1, Col 3: Action buttons -->
      <StackPanel Grid.Row="1" Grid.Column="3"
                  Spacing="6"
                  Margin="0,4,0,0"
                  VerticalAlignment="Bottom">
        <Button x:Name="NewFolderBtn"
                Command="{ReflectionBinding CreateFolderCommand}"
                IsEnabled="{ReflectionBinding CanRefresh}"
                Padding="6,4"
                Width="105"
                HorizontalContentAlignment="Stretch">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Grid>
              <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-newfolder-32.png"
                     IsVisible="{Binding #NewFolderBtn.IsEnabled}"
                     Width="24" Height="24" Stretch="Uniform"/>
              <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-newfolder-32-disabled.png"
                     IsVisible="{Binding #NewFolderBtn.IsEnabled, Converter={StaticResource BoolInverse}}"
                     Width="24" Height="24" Stretch="Uniform"/>
            </Grid>
            <TextBlock Text="New Folder"
                       FontSize="12"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
      <Button x:Name="UploadButton"
              IsEnabled="{ReflectionBinding CanModifyFiles}"
              Padding="6,4"
              Width="105"
              HorizontalContentAlignment="Stretch"
              ToolTip.Tip="{ReflectionBinding OperationLockedTooltip}">
        <Button.Flyout>
          <MenuFlyout>
            <MenuItem Header="Upload Files" x:Name="UploadFilesMenuItem">
              <MenuItem.Icon>
                <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-add-file-20.png"
                       Width="16" Height="16" Stretch="Uniform"/>
              </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Upload Folder" x:Name="UploadFolderMenuItem">
              <MenuItem.Icon>
                <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-folder-20.png"
                       Width="16" Height="16" Stretch="Uniform"/>
              </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Upload ZIP &amp; Extract" x:Name="UploadZipMenuItem">
              <MenuItem.Icon>
                <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-zip-20.png"
                       Width="16" Height="16" Stretch="Uniform"/>
              </MenuItem.Icon>
            </MenuItem>
          </MenuFlyout>
        </Button.Flyout>
        <StackPanel Orientation="Horizontal" Spacing="6">
          <Grid>
            <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-upload-48.png"
                   IsVisible="{Binding #UploadButton.IsEnabled}"
                   Width="24" Height="24" Stretch="Uniform"/>
            <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-upload-48-disabled.png"
                   IsVisible="{Binding #UploadButton.IsEnabled, Converter={StaticResource BoolInverse}}"
                   Width="24" Height="24" Stretch="Uniform"/>
          </Grid>
          <TextBlock Text="Upload"
                     FontSize="12"
                     VerticalAlignment="Center"/>
        </StackPanel>
      </Button>
        <Button x:Name="DownloadBtn"
                Command="{ReflectionBinding DownloadSelectedCommand}"
                IsEnabled="{ReflectionBinding CanDownloadMultiple}"
                Padding="6,4"
                Width="105"
                HorizontalContentAlignment="Stretch"
                ToolTip.Tip="{ReflectionBinding OperationLockedTooltip}">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Grid>
              <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-download-32.png"
                     IsVisible="{Binding #DownloadBtn.IsEnabled}"
                     Width="24" Height="24" Stretch="Uniform"/>
              <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-download-32-disabled.png"
                     IsVisible="{Binding #DownloadBtn.IsEnabled, Converter={StaticResource BoolInverse}}"
                     Width="24" Height="24" Stretch="Uniform"/>
            </Grid>
            <TextBlock Text="Download"
                       FontSize="12"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button x:Name="DeleteBtn"
                Command="{ReflectionBinding DeleteSelectedCommand}"
                IsEnabled="{ReflectionBinding CanDeleteMultiple}"
                Padding="6,4"
                Width="105"
                HorizontalContentAlignment="Stretch"
                ToolTip.Tip="{ReflectionBinding OperationLockedTooltip}">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Grid>
              <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-delete-32.png"
                     IsVisible="{Binding #DeleteBtn.IsEnabled}"
                     Width="24" Height="24" Stretch="Uniform"/>
              <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-delete-32-disabled.png"
                     IsVisible="{Binding #DeleteBtn.IsEnabled, Converter={StaticResource BoolInverse}}"
                     Width="24" Height="24" Stretch="Uniform"/>
            </Grid>
            <TextBlock Text="Delete"
                       FontSize="12"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button x:Name="RenameBtn"
                Command="{ReflectionBinding RenameEntryCommand}"
                IsEnabled="{ReflectionBinding CanRenameSingle}"
                Padding="6,4"
                Width="105"
                HorizontalContentAlignment="Stretch"
                ToolTip.Tip="{ReflectionBinding OperationLockedTooltip}">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Grid>
              <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-rename-32.png"
                     IsVisible="{Binding #RenameBtn.IsEnabled}"
                     Width="24" Height="24" Stretch="Uniform"/>
              <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-rename-32-disabled.png"
                     IsVisible="{Binding #RenameBtn.IsEnabled, Converter={StaticResource BoolInverse}}"
                     Width="24" Height="24" Stretch="Uniform"/>
            </Grid>
            <TextBlock Text="Rename"
                       FontSize="12"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
      </StackPanel>

      <!-- Row 2: Drop zone / Progress card -->
      <Border Grid.Row="2" Grid.ColumnSpan="4"
              Padding="10"
              CornerRadius="8"
              BorderThickness="2"
              Background="#0dffffff"
              BorderBrush="#33ffffff"
              Margin="0,4,0,0"
              x:Name="DropZoneBorder"
              DragDrop.AllowDrop="True">
        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,Auto,*">
          <!-- Progress bar -->
          <ProgressBar Grid.Row="0" Grid.ColumnSpan="3"
                       IsVisible="{ReflectionBinding ShowActivity}"
                       Value="{ReflectionBinding ActivityProgress}"
                       Minimum="0" Maximum="1"
                       Height="4"
                       Foreground="{StaticResource AccentBrush}"
                       Margin="0,0,0,6"/>
          <!-- CD spinner (visible during activity) -->
          <Image Grid.Row="1" Grid.Column="0"
                 x:Name="CdSpinnerImage"
                 Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-cd-48.png"
                 Width="48" Height="48"
                 Stretch="Uniform"
                 VerticalAlignment="Center"
                 Margin="4,0,12,0"
                 IsVisible="{ReflectionBinding ShowActivity}"
                 RenderTransformOrigin="50% 50%">
            <Image.RenderTransform>
              <RotateTransform Angle="0"/>
            </Image.RenderTransform>
          </Image>
          <!-- Upload icon (idle) -->
          <Image Grid.Row="1" Grid.Column="0"
                 Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-upload-48.png"
                 Width="48" Height="48"
                 Stretch="Uniform"
                 VerticalAlignment="Center"
                 Margin="4,0,12,0"
                 Opacity="0.25"
                 IsVisible="{ReflectionBinding ShowIdle}"/>
          <!-- Activity status -->
          <StackPanel Grid.Row="1" Grid.Column="1"
                      IsVisible="{ReflectionBinding ShowActivity}"
                      Spacing="4"
                      VerticalAlignment="Center">
            <TextBlock Text="{ReflectionBinding ActivityText}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextMutedBrush}"/>
            <TextBlock Text="{ReflectionBinding ActivityProgress, StringFormat={}{0:P0}}"
                       FontSize="12"
                       Foreground="{StaticResource TextDimBrush}"/>
          </StackPanel>
          <!-- Cancel button -->
          <Button Grid.Row="1" Grid.Column="2"
                  IsVisible="{ReflectionBinding ShowActivity}"
                  Command="{ReflectionBinding CancelTransferCommand}"
                  Width="28" Height="28"
                  Padding="0"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center"
                  ToolTip.Tip="Cancel">
            <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-cancel-16.png"
                   Width="14" Height="14"
                   Stretch="Uniform"/>
          </Button>
          <!-- Drop prompt (idle) -->
          <StackPanel Grid.Row="1" Grid.Column="1"
                      IsVisible="{ReflectionBinding ShowIdle}"
                      Spacing="2"
                      VerticalAlignment="Center">
            <TextBlock Text="Drop files here to upload"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextMutedBrush}"/>
            <TextBlock Text="{ReflectionBinding CurrentPath, StringFormat='Destination: {0}'}"
                       FontSize="12"
                       Foreground="{StaticResource TextDimBrush}"/>
            <TextBlock Text="Drag &amp; drop multiple files from your PC"
                       FontSize="11"
                       Foreground="{StaticResource TextDimBrush}"/>
            <Button Padding="8,4"
                    FontSize="12"
                    HorizontalAlignment="Left"
                    Margin="0,4,0,0"
                    x:Name="BrowseFilesBtn">
              <StackPanel Orientation="Horizontal" Spacing="5">
          <Image Source="avares://XBVault/Assets/Views/FileExplorerView/fileexplorer-add-file-20.png"
                        Width="16" Height="16"
                        Stretch="Uniform"
                        Opacity="0.7"/>
                <TextBlock Text="Browse Files" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>

  </Grid>

</UserControl>
