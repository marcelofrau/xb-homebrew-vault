<UserControl xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:vm="using:XBVault.ViewModels"
              xmlns:models="using:XBVault.Models"
              x:Class="XBVault.Views.InstalledView"
              Cursor="{Binding Cursor}" x:DataType="vm:InstalledViewModel">

  <UserControl.Styles>
    <Style Selector="ListBoxItem">
      <Setter Property="Padding" Value="0"/>
    </Style>
    <Style Selector="ListBoxItem:selected Border.Card">
      <Setter Property="Background" Value="#3A6E35"/>
      <Setter Property="BorderBrush" Value="#9ACA3C"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>
    <Style Selector="ListBoxItem:selected:focus Border.Card">
      <Setter Property="Background" Value="#3A6E35"/>
      <Setter Property="BorderBrush" Value="#9ACA3C"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>
    <Style Selector="ListBoxItem:pointerover Border.Card">
      <Setter Property="Background" Value="#2F5A2A"/>
    </Style>

  </UserControl.Styles>

  <Grid RowDefinitions="Auto,Auto,*" Margin="32">

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,14,0,16" ColumnDefinitions="*,Auto,Auto">
      <StackPanel>
        <TextBlock Text="INSTALLED"
                   Classes="PageTitle"/>
        <TextBlock Text="Manage apps and emulators installed on your Xbox"
                   Classes="Muted"
                   FontSize="14"
                   Margin="0,4,0,0"/>
      </StackPanel>
      <TextBlock Grid.Column="1"
                 Text="{Binding LastUpdated}"
                 FontSize="11"
                 Foreground="{StaticResource TextMutedBrush}"
                 VerticalAlignment="Top"
                 IsVisible="{Binding LastUpdated, Converter={StaticResource StringNotEmpty}}"/>
      <TextBlock Grid.Column="2"
                 Text="{Binding ToolbarStatus}"
                 FontSize="11"
                 Foreground="{StaticResource TextMutedBrush}"
                 VerticalAlignment="Top"
                 Margin="12,0,0,0"
                 IsVisible="{Binding ToolbarStatus, Converter={StaticResource StringNotEmpty}}"/>
    </Grid>

    <!-- Toolbar -->
    <Grid Grid.Row="1"
          ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto"
          Margin="0,0,0,16">

      <Button Grid.Column="0"
              Command="{Binding RefreshPackagesCommand}"
              Padding="12,8">
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
<Image Source="avares://XBVault/Assets/Views/InstalledView/installed-refresh-20.png"
                   Width="20" Height="20"
                   Stretch="Uniform"/>
          <TextBlock Grid.Column="1"
                     Text="Refresh"
                     FontSize="13"
                     VerticalAlignment="Center"/>
        </Grid>
      </Button>

      <Button Grid.Column="1"
              Command="{Binding UninstallSelectedCommand}"
              Classes="Danger"
              Padding="12,8"
              IsEnabled="{Binding IsPackageSelected}"
              Margin="8,0,0,0">
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
<Image Source="avares://XBVault/Assets/Views/InstalledView/installed-uninstall-20.png"
                   Width="20" Height="20"
                   Stretch="Uniform"/>
          <TextBlock Grid.Column="1"
                     Text="Uninstall"
                     FontSize="13"
                     VerticalAlignment="Center"/>
        </Grid>
      </Button>

      <!-- Launch (not running) -->
      <Button Grid.Column="2"
              Command="{Binding LaunchSelectedCommand}"
              Padding="12,8"
              IsVisible="{Binding IsPackageNotRunning}"
              IsEnabled="{Binding IsPackageSelected}"
              Margin="8,0,0,0">
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
          <Path Data="M7,4 L17,12 L7,20 Z"
                Fill="{StaticResource AccentBrush}"
                Width="18" Height="18"
                Stretch="Uniform"
                VerticalAlignment="Center"/>
          <TextBlock Grid.Column="1"
                     Text="Launch"
                     FontSize="13"
                     VerticalAlignment="Center"/>
        </Grid>
      </Button>

      <!-- Suspend + Terminate (running) -->
      <Button Grid.Column="2"
              Command="{Binding SuspendSelectedCommand}"
              Padding="12,8"
              IsVisible="{Binding IsPackageRunning}"
              IsEnabled="{Binding IsPackageRunning}"
              Margin="8,0,0,0">
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
          <TextBlock Text="⏸"
                     FontSize="16"
                     VerticalAlignment="Center"/>
          <TextBlock Grid.Column="1"
                     Text="Suspend"
                     FontSize="13"
                     VerticalAlignment="Center"/>
        </Grid>
      </Button>

      <Button Grid.Column="3"
              Command="{Binding TerminateSelectedCommand}"
              Padding="12,8"
              IsVisible="{Binding IsPackageRunning}"
              IsEnabled="{Binding IsPackageRunning}"
              Margin="8,0,0,0">
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
          <Image Source="avares://XBVault/Assets/Views/InstalledView/installed-terminate-16.png"
                 Width="16" Height="16" Stretch="Uniform"/>
          <TextBlock Grid.Column="1"
                     Text="Terminate"
                     FontSize="13"
                     VerticalAlignment="Center"/>
        </Grid>
      </Button>

      <TextBox Grid.Column="6"
               Text="{Binding SearchText}"
               PlaceholderText="Filter packages..."
               FontSize="13"
               Width="180"
               VerticalAlignment="Center"
               Padding="8,6"/>
    </Grid>

    <!-- Row 2 content panel (stable drag-drop target, no flicker) -->
    <Panel Grid.Row="2"
           x:Name="DropPanel"
           DragDrop.AllowDrop="True">

      <!-- Loading -->
      <StackPanel IsVisible="{Binding IsLoading}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="12">
        <Image x:Name="SpinnerImage"
               Source="avares://XBVault/Assets/Views/InstalledView/installed-spinner-48.png"
               Width="48" Height="48"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               RenderTransformOrigin="50% 50%">
          <Image.RenderTransform>
            <RotateTransform Angle="0"/>
          </Image.RenderTransform>
        </Image>
        <ProgressBar IsIndeterminate="True"
                     Width="200"
                     Foreground="{StaticResource AccentBrush}"/>
        <TextBlock Text="Loading packages..."
                   Foreground="{StaticResource TextMutedBrush}"
                   FontSize="13"
                   HorizontalAlignment="Center"/>
      </StackPanel>

      <!-- Disconnected -->
      <StackPanel IsVisible="{Binding ShowDisconnected}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="12">
        <Image Source="avares://XBVault/Assets/Views/InstalledView/installed-disconnected-64.png"
               Width="64" Height="64"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               Opacity="0.6"/>
        <TextBlock Text="Not connected"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextMutedBrush}"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="Connect to access installed packages"
                   FontSize="13"
                   Foreground="{StaticResource TextDimBrush}"
                   HorizontalAlignment="Center"/>
        <Button Command="{Binding ConnectCommand}"
                Padding="16,8"
                FontSize="14"
                HorizontalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Image Source="avares://XBVault/Assets/Views/ConnectionWindow/connection-connect-20.png"
                   Width="20" Height="20" Stretch="Uniform"/>
            <TextBlock Text="Connect" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
      </StackPanel>

      <!-- Status/Error message -->
      <StackPanel IsVisible="{Binding ShowStatus}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="12">
        <Image Source="avares://XBVault/Assets/Views/InstalledView/installed-disconnected-64.png"
               Width="64" Height="64"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               Opacity="0.6"/>
        <TextBlock Text="{Binding StatusMessage}"
                   Foreground="{StaticResource TextMutedBrush}"
                   FontSize="13"
                   HorizontalAlignment="Center"/>
      </StackPanel>

      <!-- Refresh prompt -->
      <StackPanel IsVisible="{Binding ShowRefreshPrompt}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="12">
        <Image Source="avares://XBVault/Assets/Views/InstalledView/installed-empty-64.png"
               Width="64" Height="64"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               Opacity="0.6"/>
        <TextBlock Text="No packages loaded"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextMutedBrush}"
                   HorizontalAlignment="Center"/>
        <Button Command="{Binding RefreshPackagesCommand}"
                Padding="16,8"
                FontSize="14"
                HorizontalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Image Source="avares://XBVault/Assets/Views/InstalledView/installed-refresh-20.png"
                   Width="20" Height="20" Stretch="Uniform"/>
            <TextBlock Text="Refresh" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
      </StackPanel>

      <!-- Package grid -->
      <ListBox x:Name="PackageListBox"
               ItemsSource="{Binding Packages}"
               SelectedItem="{Binding SelectedPackage}"
               BorderThickness="0"
               Background="Transparent"
               IsVisible="{Binding ShowGrid}"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled">
      <ListBox.ItemsPanel>
        <ItemsPanelTemplate>
          <UniformGrid Columns="4" VerticalAlignment="Top"/>
        </ItemsPanelTemplate>
      </ListBox.ItemsPanel>
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="models:InstalledPackage">
          <Border Classes="Card"
                  Padding="10"
                  Margin="4"
                  Height="150"
                  Cursor="Hand">
            <Grid>
              <!-- Running border overlay -->
              <Border BorderBrush="#9ACA3C"
                      BorderThickness="2"
                      CornerRadius="8"
                      IsVisible="{Binding IsRunning}"/>

              <!-- Card content -->
              <StackPanel Spacing="6" HorizontalAlignment="Center"
                          Opacity="{Binding IsUninstalling, Converter={StaticResource BoolToOpacity}}">
                <Image Source="avares://XBVault/Assets/Views/InstalledView/installed-package-32.png"
                       Width="32" Height="32"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Name}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
                <TextBlock Text="{Binding Version}"
                           FontSize="12"
                           Foreground="{StaticResource AccentBrush}"
                           TextAlignment="Center"/>
                <TextBlock Text="{Binding DisplayPublisher}"
                           FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}"
                           TextTrimming="CharacterEllipsis"
                           IsVisible="{Binding DisplayPublisher, Converter={StaticResource StringNotEmpty}}"
                           TextAlignment="Center"/>
                <TextBlock Text="{Binding StateLabel}"
                           FontSize="10"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"
                           Foreground="{StaticResource TextMutedBrush}"/>

              </StackPanel>

              <!-- Uninstall overlay -->
              <Border Background="#AA222222"
                      CornerRadius="6"
                      IsVisible="{Binding IsUninstalling}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                  <TextBlock Text="Uninstalling..."
                             FontSize="13"
                             FontWeight="SemiBold"
                             Foreground="White"
                             TextAlignment="Center"/>
                </StackPanel>
              </Border>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <!-- Drop overlay (on top of all Row 2 panels) -->
    <Border x:Name="DropOverlay"
            IsVisible="False"
            ZIndex="100"
            Background="#CC1A1A2E"
            BorderThickness="2"
            BorderBrush="#B40078D7"
            CornerRadius="12"
            Margin="4">
      <StackPanel VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Spacing="12">
        <Image Source="avares://XBVault/Assets/Icons/droppackage-64.png"
               Width="64" Height="64"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               Opacity="0.8"/>
        <TextBlock Text="Drop a package to install"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="White"
                   HorizontalAlignment="Center"/>
        <TextBlock Text=".appx, .msix, .appxbundle or .zip"
                   FontSize="12"
                   Foreground="#CCFFFFFF"
                   HorizontalAlignment="Center"/>
      </StackPanel>
    </Border>

    </Panel>

  </Grid>

</UserControl>
